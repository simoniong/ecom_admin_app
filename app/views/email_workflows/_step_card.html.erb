<%= turbo_frame_tag dom_id(step) do %>
  <div class="w-full max-w-md" data-controller="collapsible">
    <div class="bg-white shadow-sm rounded-lg border border-gray-200">
      <%# Step header - click to expand %>
      <div class="flex items-center justify-between p-4 cursor-pointer" data-action="click->collapsible#toggle">
        <div class="flex items-center gap-3">
          <% if step.delay? %>
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-orange-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-orange-600" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
          <% else %>
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-600" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
          <% end %>
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">
              <%= step.delay? ? t("email_workflows.steps.delay") : t("email_workflows.steps.send_email") %>
            </p>
            <p class="text-sm text-gray-900"><%= step.summary.presence || "—" %></p>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <%= button_to shopify_store_email_workflow_email_workflow_step_path(@shopify_store, @workflow, step),
              method: :delete,
              data: { turbo_frame: "workflow-steps-list" },
              class: "text-gray-400 hover:text-red-500 p-1",
              form: { data: { turbo_confirm: t("email_workflows.steps.step_deleted") } } do %>
            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
          <% end %>
          <svg class="w-4 h-4 text-gray-400 transition-transform" aria-hidden="true" data-collapsible-target="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </div>
      </div>

      <%# Expandable form %>
      <div class="hidden border-t border-gray-200 p-4" data-collapsible-target="content">
        <% if step.delay? %>
          <%= render "email_workflows/delay_form", step: step %>
        <% else %>
          <%= render "email_workflows/send_email_form", step: step %>
        <% end %>
      </div>
    </div>

    <%# Connector line %>
    <div class="flex justify-center">
      <div class="w-px h-6 bg-gray-300"></div>
    </div>
  </div>
<% end %>
