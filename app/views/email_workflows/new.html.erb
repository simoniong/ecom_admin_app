<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-3">
    <%= link_to shopify_store_email_workflows_path(@shopify_store), class: "text-gray-400 hover:text-gray-600" do %>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("email_workflows.new_workflow") %></h1>
  </div>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <%= form_with model: @workflow, url: shopify_store_email_workflows_path(@shopify_store), class: "space-y-6" do |f| %>
      <div>
        <label for="email_workflow_trigger_event" class="block text-sm font-medium text-gray-700 mb-1">
          <%= t("email_workflows.trigger_event") %>
        </label>
        <select name="email_workflow[trigger_event]" id="email_workflow_trigger_event"
                class="block w-full rounded-md border-gray-300 shadow-sm focus:border-gray-900 focus:ring-gray-900 sm:text-sm">
          <% @available_events.each do |event| %>
            <option value="<%= event %>" <%= "selected" if @workflow.trigger_event == event %>>
              <%= t("email_workflows.trigger_events.#{event}") %>
            </option>
          <% end %>
        </select>
      </div>

      <div>
        <%= f.submit t("email_workflows.new_workflow"),
            class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
