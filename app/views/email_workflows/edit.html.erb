<div class="max-w-3xl mx-auto" data-controller="workflow-steps"
     data-workflow-steps-create-url-value="<%= shopify_store_email_workflow_email_workflow_steps_path(@shopify_store, @workflow) %>">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to shopify_store_email_workflows_path(@shopify_store), class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-semibold text-gray-900"><%= t("email_workflows.edit_workflow") %></h1>
    </div>

    <div class="flex items-center gap-3">
      <%= form_with model: @workflow, url: shopify_store_email_workflow_path(@shopify_store, @workflow), method: :patch do |f| %>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="hidden" name="email_workflow[enabled]" value="0" />
          <input type="checkbox" name="email_workflow[enabled]" value="1"
                 <%= "checked" if @workflow.enabled? %>
                 class="sr-only peer"
                 onchange="this.form.requestSubmit()" />
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-gray-900 peer-focus:ring-offset-2 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-gray-900"></div>
          <span class="ml-2 text-sm font-medium text-gray-700">
            <%= @workflow.enabled? ? t("email_workflows.enabled") : t("email_workflows.disabled") %>
          </span>
        </label>
      <% end %>

      <%= button_to shopify_store_email_workflow_path(@shopify_store, @workflow),
          method: :delete,
          data: { turbo_confirm: t("email_workflows.deleted") },
          class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm text-red-600 hover:text-red-700 font-medium" do %>
        <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
      <% end %>
    </div>
  </div>

  <div class="mt-8">
    <%# Trigger card %>
    <div class="flex flex-col items-center">
      <div class="w-full max-w-md bg-white shadow-sm rounded-lg border border-gray-200 p-4">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-green-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Trigger</p>
            <p class="text-sm font-semibold text-gray-900"><%= t("email_workflows.trigger_events.#{@workflow.trigger_event}") %></p>
          </div>
        </div>
      </div>

      <%# Connector line %>
      <div class="w-px h-6 bg-gray-300"></div>
    </div>

    <%# Steps list %>
    <div id="workflow-steps-list" class="flex flex-col items-center">
      <% @steps.each do |step| %>
        <%= render "step_card", step: step %>
      <% end %>
    </div>

    <% if @steps.empty? %>
      <div id="workflow-empty-state" class="text-center py-4">
        <p class="text-sm text-gray-400"><%= t("email_workflows.steps.no_steps") %></p>
      </div>
    <% end %>

    <%# Add step button %>
    <div class="flex flex-col items-center mt-2" data-workflow-steps-target="addStepArea">
      <div class="relative">
        <button type="button" data-action="click->workflow-steps#toggleMenu"
                class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-500 hover:text-gray-700 transition-colors">
          <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </button>

        <%# Step type dropdown %>
        <div data-workflow-steps-target="menu" class="hidden absolute left-1/2 -translate-x-1/2 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-10">
          <button type="button" data-action="click->workflow-steps#addStep" data-step-type="delay"
                  class="w-full flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
            <svg class="w-4 h-4 text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <%= t("email_workflows.steps.delay") %>
          </button>
          <button type="button" data-action="click->workflow-steps#addStep" data-step-type="send_email"
                  class="w-full flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
            <svg class="w-4 h-4 text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <%= t("email_workflows.steps.send_email") %>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
