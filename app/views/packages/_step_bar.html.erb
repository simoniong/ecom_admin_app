<%
  main_states = %w[pending_review pending_process applying_tracking pending_label shipped]
  current_index = main_states.index(package.aasm_state)
%>
<div id="<%= dom_id(package, :step_bar) %>" class="px-6 py-4 border-b border-gray-100">
  <% if %w[refunded held].include?(package.aasm_state) %>
    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium <%= package.aasm_state == 'refunded' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %>">
      <%= t("packages.states.#{package.aasm_state}") %>
      <% if package.aasm_state == "held" && package.held_from.present? %>
        &middot; <%= t("packages.held_from_label", state: t("packages.states.#{package.held_from}")) %>
      <% end %>
    </span>
  <% else %>
    <ol class="flex items-center w-full text-xs">
      <% main_states.each_with_index do |state, index| %>
        <li class="flex items-center <%= 'flex-1' unless index == main_states.size - 1 %>">
          <span class="flex items-center justify-center w-6 h-6 rounded-full shrink-0 font-medium
            <%= index == current_index ? 'bg-blue-600 text-white' : (index < current_index ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-400') %>">
            <%= index + 1 %>
          </span>
          <span class="ml-2 whitespace-nowrap <%= index == current_index ? 'text-gray-900 font-medium' : 'text-gray-500' %>">
            <%= t("packages.states.#{state}") %>
          </span>
          <% unless index == main_states.size - 1 %>
            <span class="flex-1 h-px mx-3 <%= index < current_index ? 'bg-blue-300' : 'bg-gray-200' %>"></span>
          <% end %>
        </li>
      <% end %>
    </ol>
  <% end %>
</div>
