<div id="<%= dom_id(package, :note) %>" class="space-y-4" data-controller="edit-toggle">
  <div class="flex items-center justify-between">
    <h4 class="text-sm font-semibold text-gray-900"><%= t("packages.tabs.note") %></h4>
    <% if current_membership&.package_process? %>
      <button type="button" data-action="click->edit-toggle#edit"
              class="text-xs text-blue-600 border border-blue-200 rounded px-2 py-1 hover:bg-blue-50">
        <%= t("packages.edit") %>
      </button>
    <% else %>
      <button type="button" disabled
              class="text-xs text-gray-400 border border-gray-200 rounded px-2 py-1 cursor-not-allowed">
        <%= t("packages.edit") %>
      </button>
    <% end %>
  </div>

  <p data-edit-toggle-target="view" class="text-sm text-gray-900 whitespace-pre-wrap">
    <%= package.note.presence || t("packages.note_fields.none") %>
  </p>

  <%= form_with url: update_note_package_path(id: package.id), method: :patch,
        data: { turbo_frame: "package-modal", "edit-toggle-target": "form" },
        class: "hidden space-y-4" do %>
    <div>
      <textarea name="note" rows="4"
                class="w-full border border-gray-300 rounded px-2 py-1 text-sm"><%= package.note %></textarea>
    </div>
    <div class="flex items-center gap-2">
      <button type="submit" class="px-3 py-1.5 bg-blue-600 text-white text-xs rounded hover:bg-blue-700">
        <%= t("packages.save") %>
      </button>
      <button type="button" data-action="click->edit-toggle#cancel"
              class="px-3 py-1.5 text-xs text-gray-600 border border-gray-200 rounded hover:bg-gray-50">
        <%= t("packages.cancel") %>
      </button>
    </div>
  <% end %>
</div>
