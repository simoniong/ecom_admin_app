<%
  address = package.shipping_address_snapshot || {}
  fields = %w[name company address1 address2 city province zip country country_code phone tax_id]
  required = Package::ADDRESS_REQUIRED
%>
<div id="<%= dom_id(package, :address) %>" class="space-y-4" data-controller="edit-toggle">
  <div class="flex items-center justify-between">
    <h4 class="text-sm font-semibold text-gray-900"><%= t("packages.tabs.address") %></h4>
    <% unless package.address_complete? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
        <%= t("packages.address_fields.incomplete") %>
      </span>
    <% end %>
    <% if current_membership&.package_process? %>
      <button type="button" data-action="click->edit-toggle#edit"
              class="text-xs text-blue-600 border border-blue-200 rounded px-2 py-1 hover:bg-blue-50">
        <%= t("packages.edit") %>
      </button>
    <% else %>
      <button type="button" disabled
              class="text-xs text-gray-400 border border-gray-200 rounded px-2 py-1 cursor-not-allowed">
        <%= t("packages.edit") %>
      </button>
    <% end %>
  </div>

  <dl data-edit-toggle-target="view" class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
    <% fields.each do |field| %>
      <div>
        <dt class="text-xs text-gray-500">
          <%= t("packages.address_fields.#{field}") %><%= " *" if required.include?(field) %>
        </dt>
        <dd class="text-gray-900"><%= address[field].presence || "—" %></dd>
      </div>
    <% end %>
  </dl>

  <%= form_with url: update_address_package_path(id: package.id), method: :patch,
        data: { turbo_frame: "package-modal", "edit-toggle-target": "form" },
        class: "hidden space-y-4" do %>
    <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <% fields.each do |field| %>
        <div>
          <label class="block text-xs text-gray-500 mb-1">
            <%= t("packages.address_fields.#{field}") %><%= " *" if required.include?(field) %>
          </label>
          <input type="text" name="address[<%= field %>]" value="<%= address[field] %>"
                 class="w-full border border-gray-300 rounded px-2 py-1 text-sm" />
        </div>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <button type="submit" class="px-3 py-1.5 bg-blue-600 text-white text-xs rounded hover:bg-blue-700">
        <%= t("packages.save") %>
      </button>
      <button type="button" data-action="click->edit-toggle#cancel"
              class="px-3 py-1.5 text-xs text-gray-600 border border-gray-200 rounded hover:bg-gray-50">
        <%= t("packages.cancel") %>
      </button>
    </div>
  <% end %>
</div>
