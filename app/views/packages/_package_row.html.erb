<tr>
  <% if local_assigns[:bulk] %>
    <td class="px-4 py-3 align-top">
      <input type="checkbox" name="package_ids[]" value="<%= package.id %>"
             data-package-bulk-target="checkbox" data-action="change->package_bulk#refresh">
    </td>
  <% end %>
  <td class="px-4 py-3 text-sm font-medium align-top whitespace-nowrap">
    <%= link_to package.package_code, package_path(id: package.id),
        data: { turbo_frame: "package-modal" },
        class: "text-blue-600 hover:underline font-medium" %>
  </td>
  <td class="px-4 py-3 text-sm text-gray-700 align-top">
    <% if package.package_items.any? %>
      <% package.package_items.each do |item| %>
        <div class="whitespace-nowrap">
          <span class="font-mono text-xs text-gray-500"><%= item.sku.presence || "—" %></span>
          <span class="text-gray-400">&times;<%= item.quantity %></span>
          <span class="text-gray-700"><%= item.title %></span>
          <% if item.refunded_quantity.positive? %>
            <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium <%= item.fully_refunded? ? 'bg-red-100 text-red-800' : 'bg-amber-100 text-amber-800' %>">
              <%= t("packages.item_refunded", n: item.refunded_quantity, total: item.quantity) %><% if item.fully_refunded? %> · <%= t("packages.do_not_ship") %><% end %>
            </span>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <span class="text-gray-400">—</span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-sm text-right text-gray-900 align-top whitespace-nowrap">
    <%= number_to_currency(package.order.total_price, unit: "#{package.order.currency} ") %>
  </td>
  <td class="px-4 py-3 text-sm text-gray-700 align-top whitespace-nowrap">
    <%# Prefer the package's own address snapshot so a manual override (which
        sets address_overridden and may change the country) shows here too;
        fall back to the order's raw Shopify shipping address otherwise. %>
    <% country = package.shipping_address_snapshot["country_code"].presence ||
                 package.order.shopify_data&.dig("shipping_address", "country_code") %>
    <% if country.present? %>
      <%= parcel_country_flag(country) %> <%= parcel_country_name(country) %>
    <% else %>
      <span class="text-gray-400">—</span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-sm text-gray-700 align-top whitespace-nowrap"><%= package.order.name %></td>
  <td class="px-4 py-3 text-sm text-gray-500 align-top whitespace-nowrap"><%= package.created_at.strftime("%Y-%m-%d %H:%M") %></td>
  <td class="px-4 py-3 text-sm text-gray-700 align-top whitespace-nowrap"><%= package.logistics_channel&.name || "—" %></td>
  <td class="px-4 py-3 text-sm align-top whitespace-nowrap">
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
      <%= t("packages.states.#{package.aasm_state}") %>
    </span>
    <% if package.aasm_state == "applying_tracking" && package.application_status != "none" %>
      <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
        <%= t("packages.application_status.#{package.application_status}") %>
      </span>
    <% end %>
    <% if package.aasm_state == "held" && package.held_from.present? %>
      <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700">
        <%= t("packages.held_from_label", state: t("packages.states.#{package.held_from}")) %>
      </span>
    <% end %>
    <% if package.order_cancelled? %>
      <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
        <%= t("packages.order_cancelled") %>
      </span>
    <% end %>
  </td>
</tr>
