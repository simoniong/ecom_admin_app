<%
  order = package.order
  line_items = order.order_line_items
%>
<div id="<%= dom_id(package, :order_info) %>" class="border-t border-gray-100 px-6 py-4">
  <div class="flex items-center justify-between mb-3">
    <h4 class="text-sm font-semibold text-gray-900">
      <%= t("packages.order_info.order_name") %>: <%= order.name %>
    </h4>
    <% if package.order_cancelled? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
        <%= t("packages.order_cancelled") %>
      </span>
    <% end %>
  </div>

  <% if line_items.empty? %>
    <p class="text-sm text-gray-400"><%= t("packages.order_info.no_items") %></p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-medium text-gray-500 uppercase">
            <th class="pr-4 py-1"><%= t("packages.order_info.sku") %></th>
            <th class="pr-4 py-1"><%= t("packages.order_info.item_title") %></th>
            <th class="pr-4 py-1 text-right"><%= t("packages.order_info.quantity") %></th>
            <th class="pr-4 py-1 text-right"><%= t("packages.order_info.unit_price") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% line_items.each do |li| %>
            <tr>
              <td class="pr-4 py-1 font-mono text-xs text-gray-500"><%= li.sku_at_sale.presence || "—" %></td>
              <td class="pr-4 py-1 text-gray-900"><%= li.title_at_sale %></td>
              <td class="pr-4 py-1 text-right text-gray-700"><%= li.quantity %></td>
              <td class="pr-4 py-1 text-right text-gray-700">
                <%= li.unit_price ? number_to_currency(li.unit_price, unit: "#{order.currency} ") : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
