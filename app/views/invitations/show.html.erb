<div class="max-w-lg mx-auto mt-16">
  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-8 text-center">
    <h1 class="text-xl font-semibold text-gray-900 mb-2"><%= t("invitations.accept_title") %></h1>
    <p class="text-sm text-gray-600 mb-6">
      <%= t("invitations.accept_description", company: @invitation.company.name) %>
    </p>

    <div class="mb-6 text-left bg-gray-50 rounded-md p-4 space-y-2">
      <div class="flex justify-between text-sm">
        <span class="text-gray-500"><%= t("invitations.company_label") %></span>
        <span class="font-medium text-gray-900"><%= @invitation.company.name %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-gray-500"><%= t("invitations.role") %></span>
        <span class="font-medium text-gray-900"><%= t("invitations.roles.#{@invitation.role}") %></span>
      </div>
      <% unless @invitation.owner? %>
        <div class="flex justify-between text-sm">
          <span class="text-gray-500"><%= t("invitations.page_permissions") %></span>
          <span class="font-medium text-gray-900">
            <%= @invitation.permissions.map { |p| t("invitations.permission_labels.#{p}", default: p.humanize) }.join(", ") %>
          </span>
        </div>
      <% end %>
    </div>

    <%= button_to accept_invitation_confirm_path(token: @invitation.token),
        class: "inline-flex items-center px-6 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2" do %>
      <%= t("invitations.accept_button") %>
    <% end %>
  </div>
</div>
