<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <div>
        <h1 class="text-2xl font-semibold text-gray-900"><%= t("dashboard.title") %></h1>
        <p class="mt-1 text-sm text-gray-600"><%= t("dashboard.welcome", name: current_user.first_name.presence || current_user.email) %></p>
      </div>
      <%= render "shared/store_switcher" %>
    </div>
  </div>

  <%= render "shared/group_view_switcher" %>

  <%# Date range selector %>
  <div class="flex flex-wrap items-center gap-2 mb-6" data-controller="dashboard">
    <%# Preset buttons %>
    <% DashboardMetricsService::RANGES.keys.each do |key| %>
      <%= link_to authenticated_root_path(range: key),
          data: { turbo_frame: "dashboard_metrics", dashboard_target: "rangeButton", action: "click->dashboard#selectRange" },
          class: "px-3 py-1.5 text-sm font-medium rounded-md transition #{@range_key == key ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-100'}" do %>
        <%= t("dashboard.ranges.#{key}") %>
      <% end %>
    <% end %>

    <%# Separator %>
    <span class="text-gray-300 mx-1">|</span>

    <%# Custom date range picker %>
    <div class="flex items-center gap-2">
      <input type="date" data-dashboard-target="startDate"
             value="<%= @range_key == 'custom' ? @metrics[:date_range].first : '' %>"
             max="<%= Date.current %>"
             class="px-3 py-2 bg-white text-sm text-gray-700 border border-gray-300 rounded-md focus:border-gray-900 focus:ring-gray-900" />
      <span class="text-sm text-gray-400">—</span>
      <input type="date" data-dashboard-target="endDate"
             value="<%= @range_key == 'custom' ? @metrics[:date_range].last : '' %>"
             max="<%= Date.current %>"
             class="px-3 py-2 bg-white text-sm text-gray-700 border border-gray-300 rounded-md focus:border-gray-900 focus:ring-gray-900" />
      <button type="button" data-action="click->dashboard#submitCustomRange"
              class="px-3 py-1.5 text-sm font-medium rounded-md transition text-gray-600 hover:bg-gray-100">
        <%= t("dashboard.apply") %>
      </button>
    </div>
  </div>

  <%= turbo_frame_tag "dashboard_metrics" do %>
    <%# Date range display %>
    <p class="text-xs text-gray-500 mb-4">
      <%= l(@metrics[:date_range].first) %> — <%= l(@metrics[:date_range].last) %>
    </p>

    <%# ===== Revenue breakdown (waterfall) ===== %>
    <section class="mb-8">
      <%= render "dashboard/section_header",
          title: t("dashboard.section_revenue"),
          hint: t("dashboard.section_revenue_hint") %>
      <%= render "dashboard/revenue_waterfall", metrics: @metrics %>
    </section>

    <%# ===== Orders ===== %>
    <section class="mb-8">
      <%= render "dashboard/section_header", title: t("dashboard.section_orders") %>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <%= render "dashboard/metric_card",
            title: t("dashboard.orders"),
            value: number_with_delimiter(@metrics[:current][:orders]),
            previous: @metrics[:previous][:orders],
            current_raw: @metrics[:current][:orders] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.avg_order_value"),
            value: number_to_currency(@metrics[:current][:avg_order_value]),
            previous: @metrics[:previous][:avg_order_value],
            current_raw: @metrics[:current][:avg_order_value] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.new_customer_orders"),
            value: number_with_delimiter(@metrics[:current][:new_customer_orders]),
            previous: @metrics[:previous][:new_customer_orders],
            current_raw: @metrics[:current][:new_customer_orders] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.shipping_cost"),
            value: number_to_currency(@metrics[:current][:shipping_cost]),
            previous: @metrics[:previous][:shipping_cost],
            current_raw: @metrics[:current][:shipping_cost],
            invert_color: true %>
      </div>
    </section>

    <%# ===== Shipping ===== %>
    <%= render "dashboard/shipping_section", metrics: @metrics %>

    <%# ===== Advertising ===== %>
    <section class="mb-8">
      <%= render "dashboard/section_header", title: t("dashboard.section_advertising") %>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <%= render "dashboard/metric_card",
            title: t("dashboard.ad_spend"),
            value: number_to_currency(@metrics[:current][:ad_spend]),
            previous: @metrics[:previous][:ad_spend],
            current_raw: @metrics[:current][:ad_spend],
            invert_color: true %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.roas"),
            value: "#{@metrics[:current][:roas]}x",
            previous: @metrics[:previous][:roas],
            current_raw: @metrics[:current][:roas] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.cpa"),
            value: @metrics[:current][:cpa] ? number_to_currency(@metrics[:current][:cpa]) : "—",
            previous: @metrics[:previous][:cpa],
            current_raw: @metrics[:current][:cpa],
            invert_color: true %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.new_customer_cpa"),
            value: @metrics[:current][:new_customer_cpa] ? number_to_currency(@metrics[:current][:new_customer_cpa]) : "—",
            previous: @metrics[:previous][:new_customer_cpa],
            current_raw: @metrics[:current][:new_customer_cpa],
            invert_color: true %>
      </div>
    </section>

    <%# ===== Profit ===== %>
    <section class="mb-2">
      <%= render "dashboard/section_header",
          title: t("dashboard.section_profit"),
          hint: t("dashboard.section_profit_hint") %>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <%= render "dashboard/metric_card",
            title: t("dashboard.gross_profit"),
            value: number_to_currency(@metrics[:current][:gross_profit]),
            previous: @metrics[:previous][:gross_profit],
            current_raw: @metrics[:current][:gross_profit] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.gross_margin"),
            value: @metrics[:current][:gross_margin_pct] ? "#{@metrics[:current][:gross_margin_pct]}%" : "—",
            previous: @metrics[:previous][:gross_margin_pct],
            current_raw: @metrics[:current][:gross_margin_pct] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.net_profit"),
            value: number_to_currency(@metrics[:current][:net_profit]),
            previous: @metrics[:previous][:net_profit],
            current_raw: @metrics[:current][:net_profit] %>

        <%= render "dashboard/metric_card",
            title: t("dashboard.net_margin"),
            value: @metrics[:current][:net_margin_pct] ? "#{@metrics[:current][:net_margin_pct]}%" : "—",
            previous: @metrics[:previous][:net_margin_pct],
            current_raw: @metrics[:current][:net_margin_pct] %>
      </div>
    </section>

    <% if @metrics[:current][:cogs_coverage_pct] && @metrics[:current][:cogs_coverage_pct] < 100 %>
      <p class="mt-2 text-xs text-gray-500">
        <%= t("dashboard.cogs_coverage") %>: <%= @metrics[:current][:cogs_coverage_pct] %>%
      </p>
    <% end %>

    <% if @metrics[:current][:shipping_coverage_pct] && @metrics[:current][:shipping_coverage_pct] < 100 %>
      <p class="mt-1 text-xs text-gray-500">
        <%= t("dashboard.shipping_coverage") %>: <%= @metrics[:current][:shipping_coverage_pct] %>%
        (<%= t("dashboard.shipping_coverage_actual") %>: <%= @metrics[:current][:shipping_coverage_actual_pct] %>%
        · <%= t("dashboard.shipping_coverage_estimated") %>: <%= @metrics[:current][:shipping_coverage_estimated_pct] %>%)
      </p>
    <% end %>
  <% end %>
</div>
