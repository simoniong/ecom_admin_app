<%# locals: (metrics:) %>
<%# Renders the Gross to Net revenue waterfall. %>
<% cur = metrics[:current] %>
<% prev = metrics[:previous] %>

<div class="overflow-x-auto pb-1.5 -mx-1">
  <div class="flex items-stretch min-w-min px-1 pt-1">

    <%# Gross Revenue %>
    <div class="flex-none w-44 bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 truncate"><%= t("dashboard.gross_revenue") %></p>
      <div class="mt-1.5 text-[22px] font-semibold text-gray-900 tabular-nums"><%= number_to_currency(cur[:gross_revenue]) %></div>
      <%= render "dashboard/metric_delta", previous: prev[:gross_revenue], current_raw: cur[:gross_revenue], invert_color: false %>
    </div>

    <div class="flex-none self-center w-8 text-center text-lg font-semibold text-gray-400" aria-hidden="true">−</div>

    <%# Refunds (deduction) %>
    <div class="flex-none w-44 bg-red-50 border border-red-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 truncate"><%= t("dashboard.refunds") %></p>
      <div class="mt-1.5 text-[22px] font-semibold text-red-700 tabular-nums">−<%= number_to_currency(cur[:refunds]) %></div>
      <%= render "dashboard/metric_delta", previous: prev[:refunds], current_raw: cur[:refunds], invert_color: true %>
    </div>

    <div class="flex-none self-center w-8 text-center text-lg font-bold text-emerald-600" aria-hidden="true">=</div>

    <%# Revenue (checkpoint = Gross − Refunds) %>
    <div class="flex-none w-40 bg-gray-50 border border-dashed border-gray-300 rounded-xl p-4">
      <p class="text-xs font-medium text-gray-500 truncate"><span class="text-gray-400 font-bold mr-1">=</span><%= t("dashboard.revenue") %></p>
      <div class="mt-1.5 text-[22px] font-semibold text-gray-900 tabular-nums"><%= number_to_currency(cur[:revenue]) %></div>
      <%= render "dashboard/metric_delta", previous: prev[:revenue], current_raw: cur[:revenue], invert_color: false %>
    </div>

    <div class="flex-none self-center w-8 text-center text-lg font-semibold text-gray-400" aria-hidden="true">−</div>

    <%# Tax (deduction) %>
    <div class="flex-none w-44 bg-red-50 border border-red-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 truncate"><%= t("dashboard.tax") %></p>
      <div class="mt-1.5 text-[22px] font-semibold text-red-700 tabular-nums">−<%= number_to_currency(cur[:total_tax]) %></div>
      <%= render "dashboard/metric_delta", previous: prev[:total_tax], current_raw: cur[:total_tax], invert_color: true %>
    </div>

    <div class="flex-none self-center w-8 text-center text-lg font-semibold text-gray-400" aria-hidden="true">−</div>

    <%# Transaction Fees (deduction) %>
    <div class="flex-none w-44 bg-red-50 border border-red-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 truncate"><%= t("dashboard.transaction_fees") %></p>
      <div class="mt-1.5 text-[22px] font-semibold text-red-700 tabular-nums">−<%= number_to_currency(cur[:transaction_fees]) %></div>
      <%= render "dashboard/metric_delta", previous: prev[:transaction_fees], current_raw: cur[:transaction_fees], invert_color: true %>
      <p class="mt-1.5 text-[11px] text-gray-400 leading-tight"><%= t("dashboard.transaction_fees_note") %></p>
    </div>

    <div class="flex-none self-center w-8 text-center text-lg font-bold text-emerald-600" aria-hidden="true">=</div>

    <%# Net Revenue (result) %>
    <div class="relative flex-none w-52 bg-emerald-50 border-[1.5px] border-emerald-200 rounded-xl shadow-sm p-4">
      <span class="absolute -top-2.5 right-3 text-[10px] font-bold tracking-wide bg-emerald-600 text-white px-2 py-0.5 rounded-full"><%= t("dashboard.net_revenue_badge") %></span>
      <p class="text-xs font-semibold text-emerald-700 truncate"><%= t("dashboard.net_revenue") %></p>
      <div class="mt-1.5 text-[28px] font-semibold text-emerald-700 tabular-nums"><%= number_to_currency(cur[:net_revenue]) %></div>
      <%= render "dashboard/metric_delta", previous: prev[:net_revenue], current_raw: cur[:net_revenue], invert_color: false %>
    </div>

  </div>
</div>

<p class="mt-3 text-xs text-gray-500 leading-relaxed"><%= t("dashboard.revenue_waterfall_caption_html") %></p>
