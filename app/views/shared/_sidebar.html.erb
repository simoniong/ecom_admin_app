<aside data-sidebar-target="menu"
       class="fixed inset-y-0 left-0 z-40 w-64 bg-white border-r border-gray-200 flex flex-col -translate-x-full transition-transform duration-200 ease-in-out lg:translate-x-0 lg:static lg:z-auto lg:h-screen lg:overflow-y-auto shrink-0">
  <%# Logo / Title %>
  <div class="px-6 py-5 border-b border-gray-200 flex items-center justify-between">
    <h1 class="text-lg font-semibold text-gray-900"><%= t("app_name") %></h1>
    <button data-action="click->sidebar#close" class="text-gray-400 hover:text-gray-600 lg:hidden">
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <%# Navigation %>
  <nav class="flex-1 p-4 space-y-1">
    <%= link_to email_accounts_path, data: { action: "click->sidebar#close" },
        class: "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md #{current_page?(email_accounts_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
      <%= t("nav.email_accounts") %>
    <% end %>

    <%= link_to shopify_stores_path, data: { action: "click->sidebar#close" },
        class: "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md #{current_page?(shopify_stores_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
      </svg>
      <%= t("nav.shopify_stores") %>
    <% end %>

    <%= link_to tickets_path, data: { action: "click->sidebar#close" },
        class: "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md #{current_page?(tickets_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" />
      </svg>
      <%= t("nav.tickets") %>
    <% end %>

    <%= link_to ad_accounts_path, data: { action: "click->sidebar#close" },
        class: "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md #{current_page?(ad_accounts_path) ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'}" do %>
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38a.75.75 0 0 1-1.006-.327 19.23 19.23 0 0 1-1.282-3.095m2.423-6.252a21.247 21.247 0 0 0 0 6.252m6.996-3.126c0 2.533-.655 4.914-1.806 6.987m0-13.974c1.15 2.073 1.806 4.454 1.806 6.987m0 0h1.5" />
      </svg>
      <%= t("nav.ad_accounts") %>
    <% end %>
  </nav>

  <%# Bottom: Language switcher + Profile + Logout %>
  <div class="p-4 border-t border-gray-200 space-y-3">
    <%# Language switcher %>
    <div class="flex items-center gap-1 px-3 text-xs text-gray-400">
      <% I18n.available_locales.each_with_index do |loc, i| %>
        <% if i > 0 %><span>·</span><% end %>
        <% if loc == I18n.locale %>
          <span class="text-gray-700 font-medium"><%= t("language_name", locale: loc) %></span>
        <% else %>
          <%= link_to t("language_name", locale: loc), url_for(locale: loc), class: "hover:text-gray-600" %>
        <% end %>
      <% end %>
    </div>

    <%# Profile %>
    <div class="flex items-center gap-3 px-3 py-2">
      <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center text-xs font-medium text-gray-600 shrink-0">
        <%= current_user.email.first.upcase %>
      </div>
      <span class="text-sm text-gray-700 truncate"><%= current_user.email %></span>
    </div>

    <%# Logout %>
    <%= button_to destroy_user_session_path, method: :delete,
        class: "w-full flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-md" do %>
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
      </svg>
      <%= t("nav.sign_out") %>
    <% end %>
  </div>
</aside>
