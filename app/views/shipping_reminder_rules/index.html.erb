<div class="max-w-4xl mx-auto px-4 py-8">
  <%# Header %>
  <div class="mb-6">
    <%= link_to edit_company_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-2" do %>
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      <%= t("shipping_reminders.back") %>
    <% end %>
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("shipping_reminders.title") %></h1>
  </div>

  <%# Reminder Rules Section %>
  <div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
    <h2 class="text-sm font-medium text-gray-500 mb-4"><%= t("shipping_reminders.reminder_content") %></h2>

    <div class="space-y-3">
      <% @rules.each do |rule| %>
        <%= render "shipping_reminder_rules/rule_form", rule: rule %>
      <% end %>
    </div>
  </div>

  <%# Email Reminder Settings Section %>
  <%= render "shipping_reminder_rules/email_settings_form", setting: @setting %>
</div>
