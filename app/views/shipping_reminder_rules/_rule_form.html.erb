<div class="border border-gray-200 rounded-lg" data-controller="collapsible">
  <%# Accordion Header %>
  <button type="button" data-action="click->collapsible#toggle"
          class="w-full flex items-center justify-between px-4 py-3 text-left hover:bg-gray-50 rounded-lg">
    <span class="text-sm font-medium text-gray-900">
      Rule: <%= t("shipping_reminders.rules.#{rule.rule_type}") %>
    </span>
    <svg data-collapsible-target="icon" class="w-5 h-5 text-gray-400 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <%# Accordion Content %>
  <div data-collapsible-target="content" class="hidden">
    <div class="px-4 pb-4">
      <% url = rule.persisted? ? shipping_reminder_rule_path(rule) : shipping_reminder_rules_path %>
      <% method = rule.persisted? ? :patch : :post %>
      <%= form_with model: rule, url: url, method: method, data: { controller: "threshold-items" } do |f| %>
        <%= f.hidden_field :rule_type %>

        <div data-threshold-items-target="container" class="space-y-3">
          <% (rule.country_thresholds.presence || []).each_with_index do |threshold, index| %>
            <% if rule.rule_type == "tracking_stopped" %>
              <%= render "shipping_reminder_rules/threshold_row_stopped", rule: rule, threshold: threshold, index: index, top_countries: @top_countries, all_countries: @all_countries %>
            <% else %>
              <%= render "shipping_reminder_rules/threshold_row", rule: rule, threshold: threshold, index: index, top_countries: @top_countries, all_countries: @all_countries %>
            <% end %>
          <% end %>
        </div>

        <%# Template for new rows %>
        <template data-threshold-items-target="template">
          <% if rule.rule_type == "tracking_stopped" %>
            <div data-threshold-row class="flex items-center gap-3 py-2">
              <svg class="w-4 h-4 text-gray-300 shrink-0 cursor-grab" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
              <span class="text-sm text-gray-600 whitespace-nowrap"><%= t("shipping_reminders.remind_tracking_stopped") %></span>
              <%= render "shipping_reminder_rules/country_select", top_countries: @top_countries, all_countries: @all_countries, selected: nil %>
              <span class="text-sm text-gray-600 whitespace-nowrap"><%= t("shipping_reminders.descriptions.tracking_stopped") %></span>
              <button type="button" data-action="click->threshold-items#remove" class="text-gray-400 hover:text-red-500 shrink-0">
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          <% else %>
            <div data-threshold-row class="flex items-center gap-3 py-2">
              <svg class="w-4 h-4 text-gray-300 shrink-0 cursor-grab" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
              <span class="text-sm text-gray-600 whitespace-nowrap"><%= t("shipping_reminders.remind_when") %></span>
              <%= render "shipping_reminder_rules/country_select", top_countries: @top_countries, all_countries: @all_countries, selected: nil %>
              <span class="text-sm text-gray-600 whitespace-nowrap"><%= t("shipping_reminders.descriptions.#{rule.rule_type}") %></span>
              <input type="number" name="shipping_reminder_rule[country_thresholds][][days]"
                     value="<%= ShippingReminderRule::DEFAULT_DAYS[rule.rule_type] || 14 %>" min="1"
                     class="w-20 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
              <span class="text-sm text-gray-600"><%= t("shipping_reminders.days") %></span>
              <button type="button" data-action="click->threshold-items#remove" class="text-gray-400 hover:text-red-500 shrink-0">
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          <% end %>
        </template>

        <%# Add item button %>
        <button type="button" data-action="click->threshold-items#add"
                class="mt-3 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <%= t("shipping_reminders.add_item") %>
        </button>

        <div class="mt-4 flex justify-end">
          <%= f.submit t("shipping_reminders.save"), class: "px-4 py-2 text-sm font-medium text-white bg-gray-900 rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-500 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
