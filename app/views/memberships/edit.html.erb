<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to invitations_path, class: "text-gray-500 hover:text-gray-700" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("memberships.edit_title") %></h1>
  </div>

  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-200">
      <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center text-sm font-medium text-gray-600 shrink-0">
        <%= @membership.user.email.first.upcase %>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-900"><%= @membership.user.email %></p>
        <p class="text-xs text-gray-500"><%= t("invitations.roles.#{@membership.role}") %></p>
      </div>
    </div>

    <%= form_with model: @membership, url: membership_path(@membership), method: :patch do |f| %>
      <div class="space-y-4">
        <div>
          <span class="block text-sm font-medium text-gray-700 mb-2"><%= t("invitations.page_permissions") %></span>
          <%= hidden_field_tag "membership[permissions][]", "" %>
          <div class="grid grid-cols-2 gap-2">
            <% Membership::AVAILABLE_PERMISSIONS.each do |perm| %>
              <label class="flex items-center gap-2 text-sm text-gray-700">
                <%= check_box_tag "membership[permissions][]", perm, @membership.permissions.include?(perm), id: "perm_#{perm}" %>
                <%= t("invitations.permission_labels.#{perm}", default: perm.humanize) %>
              </label>
            <% end %>
          </div>
        </div>

        <div class="flex items-center gap-3 pt-4">
          <%= f.submit t("memberships.save"), class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
          <%= link_to t("memberships.cancel"), invitations_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
