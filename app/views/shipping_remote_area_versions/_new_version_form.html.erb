<div class="bg-white border border-gray-200 rounded-lg shadow-sm p-5 mb-6">
  <h2 class="text-sm font-medium text-gray-700 mb-3"><%= t("remote_areas.new_version_title") %></h2>
  <%= form_with url: shipping_remote_area_versions_path, method: :post, local: true,
                class: "grid grid-cols-2 md:grid-cols-4 gap-3 items-end" do %>
    <label class="text-sm text-gray-700"><%= t("remote_areas.columns.name") %>
      <input type="text" name="shipping_remote_area_version[name]" required
             class="block w-full mt-1 border border-gray-300 rounded px-2 py-1 text-sm">
    </label>
    <label class="text-sm text-gray-700"><%= t("remote_areas.columns.country") %>
      <select name="shipping_remote_area_version[country_code]" required
              class="block w-full mt-1 border border-gray-300 rounded px-2 py-1 text-sm">
        <option value=""><%= t("remote_areas.select_prompt") %></option>
        <% PostalNormalizer::SUPPORTED_COUNTRIES.each do |code| %>
          <option value="<%= code %>"><%= t("shipping_rate_cards.countries.#{code}", default: code) %> (<%= code %>)</option>
        <% end %>
      </select>
    </label>
    <label class="text-sm text-gray-700"><%= t("remote_areas.columns.effective_from") %>
      <input type="date" name="shipping_remote_area_version[effective_from]" required
             class="block w-full mt-1 border border-gray-300 rounded px-2 py-1 text-sm">
    </label>
    <label class="text-sm text-gray-700"><%= t("remote_areas.columns.effective_to") %>
      <input type="date" name="shipping_remote_area_version[effective_to]"
             class="block w-full mt-1 border border-gray-300 rounded px-2 py-1 text-sm">
    </label>
    <div>
      <button type="submit"
              class="px-3 py-1.5 text-sm bg-blue-600 text-white rounded hover:bg-blue-700">
        <%= t("remote_areas.create_version") %>
      </button>
    </div>
  <% end %>
</div>
