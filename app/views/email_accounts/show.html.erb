<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to email_accounts_path, class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-semibold text-gray-900"><%= @email_account.email %></h1>
    </div>

    <%= button_to email_account_path(@email_account), method: :delete,
        data: { turbo_confirm: t("email_accounts.disconnect_confirm") },
        class: "inline-flex items-center gap-2 px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" do %>
      <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.181 8.68a4.503 4.503 0 0 1 1.903 6.405m-9.768-2.782L3.56 14.06a4.5 4.5 0 0 0 6.364 6.365l.164-.164m-3.07-8.355-2.122 2.122a4.5 4.5 0 0 0 6.364 6.364l2.122-2.122M10.5 13.5l3-3m2.818-2.818L18.56 5.44a4.5 4.5 0 0 0-6.364-6.364l-.164.163m3.07 8.355 2.122-2.122a4.5 4.5 0 0 0-6.364-6.364l-2.122 2.122" />
      </svg>
      <%= t("email_accounts.disconnect") %>
    <% end %>
  </div>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200">
    <dl class="divide-y divide-gray-200">
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.email") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @email_account.email %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.google_uid") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono text-xs"><%= @email_account.google_uid %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.access_token") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono text-xs truncate"><%= @email_account.access_token %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.refresh_token") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono text-xs truncate"><%= @email_account.refresh_token %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.token_expires_at") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <%= @email_account.token_expires_at ? l(@email_account.token_expires_at, format: :long) : "—" %>
        </dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.scopes") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono text-xs"><%= @email_account.scopes.presence || "—" %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("email_accounts.show.connected_at") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= l(@email_account.created_at, format: :long) %></dd>
      </div>
    </dl>
  </div>

  <div class="mt-8 bg-white shadow-sm rounded-lg border border-gray-200" data-testid="send-window-section">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900"><%= t("email_accounts.show.send_window_title") %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t("email_accounts.show.send_window_description") %></p>
    </div>

    <%= form_with(model: @email_account, url: email_account_path(@email_account), method: :patch, class: "px-6 py-4") do |f| %>
      <% if @email_account.errors.any? %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md">
          <% @email_account.errors.full_messages.each do |msg| %>
            <p class="text-sm text-red-600"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2">
          <label class="text-sm font-medium text-gray-700"><%= t("email_accounts.show.send_window_from") %></label>
          <div class="flex items-center gap-1">
            <%= f.select :send_window_from_hour, (0..23).map { |h| [format("%02d", h), h] },
                {}, class: "block rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
            <span class="text-gray-500">:</span>
            <%= f.select :send_window_from_minute, (0..59).step(15).map { |m| [format("%02d", m), m] },
                {}, class: "block rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <label class="text-sm font-medium text-gray-700"><%= t("email_accounts.show.send_window_to") %></label>
          <div class="flex items-center gap-1">
            <%= f.select :send_window_to_hour, (0..23).map { |h| [format("%02d", h), h] },
                {}, class: "block rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
            <span class="text-gray-500">:</span>
            <%= f.select :send_window_to_minute, (0..59).step(15).map { |m| [format("%02d", m), m] },
                {}, class: "block rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
          </div>
        </div>

        <%= f.submit t("email_accounts.show.send_window_save"),
            class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="mt-8 bg-white shadow-sm rounded-lg border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900"><%= t("email_accounts.show.discord_title") %></h2>
      <p class="mt-1 text-sm text-gray-500"><%= t("email_accounts.show.discord_description") %></p>
    </div>

    <%= form_with(model: @email_account, url: email_account_path(@email_account), method: :patch, class: "px-6 py-4") do |f| %>
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2">
          <label class="text-sm font-medium text-gray-700"><%= t("email_accounts.show.discord_agent_mention") %></label>
          <%= f.text_field :discord_agent_mention, placeholder: "<@1234567890>",
              class: "block w-64 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 font-mono focus:border-blue-500 focus:ring-blue-500" %>
        </div>
        <%= f.submit t("email_accounts.show.discord_save"),
            class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 cursor-pointer" %>
      </div>
      <p class="mt-2 text-xs text-gray-400"><%= t("email_accounts.show.discord_agent_mention_hint_html") %></p>
    <% end %>
  </div>
</div>
