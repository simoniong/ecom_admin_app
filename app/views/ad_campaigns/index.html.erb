<%
  # All available columns and their definitions
  all_columns = CampaignDisplayTemplate::ALL_COLUMNS
  # Visible columns from active template (ordered), or all columns
  visible = @active_template ? @active_template.visible_columns : all_columns
  # For the popover, show columns in template order first, then remaining
  ordered_columns = if @active_template
    visible + (all_columns - visible)
  else
    all_columns
  end

  # Column definitions: [key, alignment, formatter]
  col_defs = {
    "ad_account"             => [:left,  ->(c, m) { c.ad_account.account_name || c.ad_account.account_id }],
    "daily_budget"           => [:right, ->(c, m) { number_to_currency(c.daily_budget) }],
    "impressions"            => [:right, ->(c, m) { number_with_delimiter(m.impressions) }],
    "clicks"                 => [:right, ->(c, m) { number_with_delimiter(m.clicks) }],
    "ctr"                    => [:right, ->(c, m) { "#{m.ctr}%" }],
    "cpc"                    => [:right, ->(c, m) { number_to_currency(m.cpc) }],
    "add_to_cart"            => [:right, ->(c, m) { number_with_delimiter(m.add_to_cart) }],
    "atc_click_rate"         => [:right, ->(c, m) { "#{m.atc_click_rate}%" }],
    "cost_per_atc"           => [:right, ->(c, m) { number_to_currency(m.cost_per_atc) }],
    "checkout_initiated"     => [:right, ->(c, m) { number_with_delimiter(m.checkout_initiated) }],
    "checkout_atc_rate"      => [:right, ->(c, m) { "#{m.checkout_atc_rate}%" }],
    "cost_per_checkout"      => [:right, ->(c, m) { number_to_currency(m.cost_per_checkout) }],
    "purchases"              => [:right, ->(c, m) { number_with_delimiter(m.purchases) }],
    "purchase_checkout_rate" => [:right, ->(c, m) { "#{m.purchase_checkout_rate}%" }],
    "purchase_click_rate"    => [:right, ->(c, m) { "#{m.purchase_click_rate}%" }],
    "cost_per_purchase"      => [:right, ->(c, m) { number_to_currency(m.cost_per_purchase) }],
    "spend"                  => [:right, ->(c, m) { number_to_currency(m.spend) }],
    "conversion_value"       => [:right, ->(c, m) { number_to_currency(m.conversion_value) }],
    "roas"                   => [:right, ->(c, m) { "#{m.roas}x" }],
  }
%>

<div class="space-y-6"
     data-controller="campaign-filter ad-column-toggle"
     data-ad-column-toggle-active-template-id-value="<%= @active_template&.id %>"
     data-ad-column-toggle-create-url-value="<%= campaign_display_templates_path %>"
     data-delete-confirm="<%= t('campaign_display_templates.delete_confirm') %>">
  <h1 class="text-2xl font-bold text-gray-900"><%= t("ad_campaigns.title") %></h1>

  <%# Column toggle modal (full-screen overlay) %>
  <div data-ad-column-toggle-target="dropdown"
       class="hidden fixed inset-0 z-50">
    <div data-action="click->ad-column-toggle#backdropClick"
         class="fixed inset-0 bg-gray-900/50 flex items-center justify-center p-4">
      <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[85vh] flex flex-col"
           data-action="click->ad-column-toggle#stopPropagation">
        <%# Modal header %>
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between shrink-0">
          <h2 class="text-lg font-semibold text-gray-900"><%= t("campaign_display_templates.select_columns") %></h2>
          <button type="button" data-action="click->ad-column-toggle#toggle"
                  class="text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <%# Scrollable column list %>
        <div class="flex-1 overflow-y-auto px-6 py-4" data-ad-column-toggle-target="list">
          <% ordered_columns.each do |col_id| %>
            <% checkbox_id = "column_toggle_#{col_id}" %>
            <div data-ad-column-toggle-target="item" data-column="<%= col_id %>"
                 class="flex items-center gap-3 px-3 py-2.5 rounded-md hover:bg-gray-50 transition-colors">
              <span data-drag-handle class="cursor-grab text-gray-300 hover:text-gray-500 select-none text-lg">&#10495;</span>
              <input type="checkbox"
                     id="<%= checkbox_id %>"
                     data-ad-column-toggle-target="checkbox"
                     data-column="<%= col_id %>"
                     data-action="change->ad-column-toggle#columnChanged"
                     <%= "checked" if visible.include?(col_id) %>
                     class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
              <label for="<%= checkbox_id %>" class="text-sm text-gray-700 select-none cursor-pointer flex-1"><%= t("ad_campaigns.columns.#{col_id}") %></label>
            </div>
          <% end %>
        </div>

        <%# Modal footer — template actions %>
        <div class="px-6 py-4 border-t border-gray-200 space-y-3 shrink-0">
          <%# Update / Delete current template %>
          <% if @active_template %>
            <div class="flex items-center gap-2">
              <button type="button"
                      data-action="click->ad-column-toggle#updateTemplate"
                      class="flex-1 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">
                <%= t("campaign_display_templates.update_template") %>
              </button>
              <button type="button"
                      data-action="click->ad-column-toggle#deleteTemplate"
                      class="px-4 py-2 text-sm font-medium text-red-600 bg-white border border-red-300 rounded-md hover:bg-red-50">
                <%= t("campaign_display_templates.delete") %>
              </button>
            </div>
          <% end %>

          <%# Save as new template %>
          <button type="button"
                  data-action="click->ad-column-toggle#showSaveSection"
                  class="w-full text-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
            <%= t("campaign_display_templates.save_as_new") %>
          </button>

          <%# Save-as-new form (hidden initially) %>
          <div data-ad-column-toggle-target="saveSection" class="hidden space-y-2">
            <input type="text"
                   data-ad-column-toggle-target="nameInput"
                   placeholder="<%= t('campaign_display_templates.template_name') %>"
                   class="block w-full px-3 py-2 text-sm bg-white border border-gray-300 rounded-md focus:border-blue-500 focus:ring-blue-500">
            <div class="flex gap-2">
              <button type="button"
                      data-action="click->ad-column-toggle#saveAsNew"
                      class="flex-1 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">
                <%= t("campaign_display_templates.save") %>
              </button>
              <button type="button"
                      data-action="click->ad-column-toggle#hideSaveSection"
                      class="px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
                <%= t("campaign_display_templates.cancel") %>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Filters %>
  <%= form_tag ad_campaigns_path, method: :get, data: { campaign_filter_target: "filterForm" }, class: "bg-white rounded-lg border border-gray-200 p-4 space-y-4" do %>
    <% if @active_template %>
      <input type="hidden" name="template_id" value="<%= @active_template.id %>">
    <% end %>
    <input type="hidden" name="status_filter" value="<%= @status_filter %>" data-campaign-filter-target="statusFilter">
    <input type="hidden" name="sort_column" value="<%= @sort_column %>" data-campaign-filter-target="sortColumn">
    <input type="hidden" name="sort_direction" value="<%= @sort_direction %>" data-campaign-filter-target="sortDirection">

    <div class="flex flex-wrap items-end gap-4">
      <%# Store selector (only if multiple stores) %>
      <% if @show_store_selector %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= t("shopify_stores.title") %></label>
          <div class="relative">
            <select name="shopify_store_id"
                    data-campaign-filter-target="storeSelect"
                    data-action="change->campaign-filter#storeChanged"
                    class="appearance-none block w-48 pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
              <% @shopify_stores.each do |store| %>
                <option value="<%= store.id %>" <%= "selected" if @selected_store == store %>><%= store.shop_domain.sub(".myshopify.com", "") %></option>
              <% end %>
            </select>
            <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>
      <% else %>
        <% if @selected_store %>
          <input type="hidden" name="shopify_store_id" value="<%= @selected_store.id %>">
        <% end %>
      <% end %>

      <%# Ad Account filter (only if multiple accounts) %>
      <% if @ad_accounts.size > 1 %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= t("nav.ad_accounts") %></label>
          <div class="relative">
            <select name="ad_account_id"
                    data-action="change->campaign-filter#submit"
                    class="appearance-none block w-48 pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
              <option value="all" <%= "selected" unless @selected_account %>><%= t("ad_campaigns.all_accounts") %></option>
              <% @ad_accounts.each do |account| %>
                <option value="<%= account.id %>" <%= "selected" if @selected_account == account %>><%= account.account_name || account.account_id %></option>
              <% end %>
            </select>
            <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>
      <% end %>

      <%# Date range inputs %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t("ad_campaigns.from_date") %></label>
        <input type="date" name="from_date" value="<%= @from_date %>"
               data-campaign-filter-target="fromDate"
               data-action="change->campaign-filter#dateChanged"
               class="block w-40 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t("ad_campaigns.to_date") %></label>
        <input type="date" name="to_date" value="<%= @to_date %>"
               data-campaign-filter-target="toDate"
               data-action="change->campaign-filter#dateChanged"
               class="block w-40 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
      </div>
    </div>

    <%# Date range quick picks %>
    <div class="flex flex-wrap gap-2">
      <% %w[today yesterday last_7_days this_week last_week last_30_days this_month last_month this_quarter last_quarter maximum].each do |range| %>
        <button type="button"
                data-campaign-filter-target="rangeButton"
                data-action="click->campaign-filter#selectRange"
                data-range="<%= range %>"
                class="px-3 py-1 text-xs font-medium rounded-full border border-gray-300 bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
          <%= t("ad_campaigns.ranges.#{range}") %>
        </button>
      <% end %>
    </div>
  <% end %>

  <%# Sync button + Template dropdown + Column toggle icon %>
  <div class="flex items-center justify-end gap-2">
    <button type="button"
            data-action="click->ad-column-toggle#syncAds"
            data-sync-url="<%= sync_ad_campaigns_path %>"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-gray-900 rounded-md hover:bg-gray-800 disabled:opacity-50 disabled:cursor-not-allowed">
      <svg class="w-4 h-4" data-ad-column-toggle-target="syncIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182M2.985 14.652" />
      </svg>
      <span data-ad-column-toggle-target="syncLabel"
            data-syncing-text="<%= t('ad_campaigns.syncing') %>"
            data-done-text="<%= t('ad_campaigns.sync_done') %>"><%= t("ad_campaigns.sync_ads") %></span>
    </button>
    <% if @templates.any? %>
      <div class="relative">
        <select data-ad-column-toggle-target="templateSelect"
                data-action="change->ad-column-toggle#templateChanged"
                class="appearance-none block w-48 pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
          <% @templates.each do |tpl| %>
            <option value="<%= tpl.id %>" <%= "selected" if @active_template == tpl %>><%= tpl.name %></option>
          <% end %>
        </select>
        <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </div>
    <% end %>
    <button type="button"
            data-action="click->ad-column-toggle#toggle"
            class="inline-flex items-center justify-center w-10 h-10 rounded-md border border-gray-300 bg-white text-gray-500 hover:bg-gray-50 hover:text-gray-700"
            title="<%= t('campaign_display_templates.select_columns') %>">
      <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z" />
      </svg>
    </button>
  </div>

  <%# Campaigns table %>
  <% if @campaigns.any? %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200" data-ad-table>
        <thead class="bg-gray-50">
          <tr>
            <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap"><%= t("ad_campaigns.columns.campaign_name") %></th>
            <th class="px-3 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">
              <select data-action="change->campaign-filter#statusChanged"
                      data-campaign-filter-target="statusSelect"
                      class="text-xs font-medium text-gray-500 uppercase tracking-wider bg-transparent border-none p-0 focus:ring-0 cursor-pointer">
                <option value="" <%= "selected" if @status_filter.blank? %>><%= t("ad_campaigns.all_statuses") %></option>
                <% %w[active paused deleted has_spend].each do |s| %>
                  <option value="<%= s %>" <%= "selected" if @status_filter == s %>><%= t("ad_campaigns.status.#{s}") %></option>
                <% end %>
              </select>
            </th>
            <%
              sortable_columns = AdCampaignsController::SORTABLE_COLUMNS
              up_arrow = '<svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" /></svg>'
              down_arrow = '<svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>'
              both_arrows = '<svg class="w-3 h-3 opacity-30" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15 12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" /></svg>'
            %>
            <% ordered_columns.each do |col| %>
              <% align = col_defs[col]&.first == :left ? "text-left" : "text-right" %>
              <% if sortable_columns.include?(col) %>
                <th data-column="<%= col %>" class="px-3 py-3 <%= align %> text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap <%= 'hidden' unless visible.include?(col) %>">
                  <button type="button" data-action="click->campaign-filter#sortBy" data-sort-column="<%= col %>"
                          class="inline-flex items-center gap-1 uppercase tracking-wider hover:text-gray-700">
                    <%= t("ad_campaigns.columns.#{col}") %>
                    <% if @sort_column == col %>
                      <%= raw(@sort_direction == "asc" ? up_arrow : down_arrow) %>
                    <% else %>
                      <%= raw(both_arrows) %>
                    <% end %>
                  </button>
                </th>
              <% else %>
                <th data-column="<%= col %>" class="px-3 py-3 <%= align %> text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap <%= 'hidden' unless visible.include?(col) %>"><%= t("ad_campaigns.columns.#{col}") %></th>
              <% end %>
            <% end %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @campaigns.each do |campaign| %>
            <% m = @campaign_metrics[campaign.id] %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-3 text-sm font-medium text-gray-900 whitespace-nowrap"><%= campaign.campaign_name || campaign.campaign_id %></td>
              <td class="px-3 py-3 whitespace-nowrap">
                <% if campaign.status == "active" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><%= t("ad_campaigns.status.active") %></span>
                <% elsif campaign.status == "paused" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800"><%= t("ad_campaigns.status.paused") %></span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= t("ad_campaigns.status.#{campaign.status}") %></span>
                <% end %>
              </td>
              <% ordered_columns.each do |col| %>
                <% align = col_defs[col]&.first == :left ? "text-left" : "text-right" %>
                <% formatter = col_defs[col]&.last %>
                <% value = formatter ? formatter.call(campaign, m) : "" %>
                <% font = col == "roas" ? "font-medium text-gray-900" : "text-gray-700" %>
                <td data-column="<%= col %>" class="px-3 py-3 text-sm <%= font %> <%= align %> whitespace-nowrap <%= 'hidden' unless visible.include?(col) %>"><%= value %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
        <% if @campaigns.size > 1 %>
          <%
            sm = @summary_metrics
            summary_defs = {
              "ad_account"             => nil,
              "daily_budget"           => -> { number_to_currency(@summary_budget) },
              "impressions"            => -> { number_with_delimiter(sm.impressions) },
              "clicks"                 => -> { number_with_delimiter(sm.clicks) },
              "ctr"                    => -> { "#{sm.ctr}%" },
              "cpc"                    => -> { number_to_currency(sm.cpc) },
              "add_to_cart"            => -> { number_with_delimiter(sm.add_to_cart) },
              "atc_click_rate"         => -> { "#{sm.atc_click_rate}%" },
              "cost_per_atc"           => -> { number_to_currency(sm.cost_per_atc) },
              "checkout_initiated"     => -> { number_with_delimiter(sm.checkout_initiated) },
              "checkout_atc_rate"      => -> { "#{sm.checkout_atc_rate}%" },
              "cost_per_checkout"      => -> { number_to_currency(sm.cost_per_checkout) },
              "purchases"              => -> { number_with_delimiter(sm.purchases) },
              "purchase_checkout_rate" => -> { "#{sm.purchase_checkout_rate}%" },
              "purchase_click_rate"    => -> { "#{sm.purchase_click_rate}%" },
              "cost_per_purchase"      => -> { number_to_currency(sm.cost_per_purchase) },
              "spend"                  => -> { number_to_currency(sm.spend) },
              "conversion_value"       => -> { number_to_currency(sm.conversion_value) },
              "roas"                   => -> { "#{sm.roas}x" },
            }
          %>
          <tfoot class="bg-gray-50 border-t-2 border-gray-300">
            <tr>
              <td class="px-3 py-3 text-sm font-semibold text-gray-900 whitespace-nowrap"><%= t("ad_campaigns.summary") %></td>
              <td></td>
              <% ordered_columns.each do |col| %>
                <% align = col_defs[col]&.first == :left ? "text-left" : "text-right" %>
                <% formatter = summary_defs[col] %>
                <% if formatter %>
                  <td data-column="<%= col %>" class="px-3 py-3 text-sm font-semibold text-gray-900 <%= align %> whitespace-nowrap <%= 'hidden' unless visible.include?(col) %>"><%= formatter.call %></td>
                <% else %>
                  <td data-column="<%= col %>" class="px-3 py-3 text-sm font-semibold text-gray-900 <%= align %> whitespace-nowrap <%= 'hidden' unless visible.include?(col) %>"></td>
                <% end %>
              <% end %>
            </tr>
          </tfoot>
        <% end %>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500"><%= t("ad_campaigns.empty") %></p>
    </div>
  <% end %>
</div>
