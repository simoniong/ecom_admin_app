<%#
  Renders a PATCH button_to that transitions a ticket to a target status.

  Locals:
    ticket        - Ticket instance
    target_status - target status string (e.g. "draft", "new_ticket")
    label         - translated button text
    color         - "yellow" | "green" | "blue"
    icon          - "pencil" | "check" | "reset"
    confirm       - optional turbo_confirm prompt (nil to omit)
%>
<%
  color_classes = {
    "yellow" => "bg-yellow-600 hover:bg-yellow-700 focus:ring-yellow-500",
    "green"  => "bg-green-600 hover:bg-green-700 focus:ring-green-500",
    "blue"   => "bg-blue-500 hover:bg-blue-600 focus:ring-blue-400"
  }.fetch(color)

  icon_path = {
    "pencil" => "m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125",
    "check"  => "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
    "reset"  => "M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"
  }.fetch(icon)

  button_classes = "inline-flex items-center gap-1.5 px-4 py-2 text-white text-sm font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 cursor-pointer #{color_classes}"
  button_data    = local_assigns[:confirm].present? ? { turbo_confirm: local_assigns[:confirm] } : {}
%>
<%= button_to ticket_path(id: ticket.id),
              method: :patch,
              class: button_classes,
              params: { ticket: { status: target_status } },
              data: button_data do %>
  <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="<%= icon_path %>" />
  </svg>
  <%= label %>
<% end %>
