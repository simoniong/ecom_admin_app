<div class="max-w-4xl mx-auto">
  <%# Header %>
  <div class="flex items-center gap-3">
    <%= link_to tickets_path, class: "text-gray-400 hover:text-gray-600" do %>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-semibold text-gray-900"><%= @ticket.subject || t("tickets.no_subject") %></h1>
      <p class="text-sm text-gray-500">
        <%= @ticket.customer_name || @ticket.customer_email %> &middot;
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= ticket_status_badge_classes(@ticket.status) %>">
          <%= t("tickets.status.#{@ticket.status}") %>
        </span>
      </p>
    </div>
  </div>

  <%# Mobile: Collapsible info panel above messages %>
  <div class="mt-4 lg:hidden" data-controller="collapsible">
    <button data-action="click->collapsible#toggle"
            class="w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-200 shadow-sm text-sm font-medium text-gray-700">
      <span><%= t("tickets.show.details") %></span>
      <svg data-collapsible-target="icon" class="w-4 h-4 text-gray-400 transition-transform" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </button>
    <div data-collapsible-target="content" class="hidden mt-3 space-y-4">
      <%= render "tickets/info_panel" %>
    </div>
  </div>

  <%# Draft Reply Section %>
  <% if @ticket.new_ticket? || @ticket.draft? %>
    <div class="mt-4 <%= @ticket.draft? ? 'bg-yellow-50 border-yellow-200' : 'bg-blue-50 border-blue-200' %> border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold <%= @ticket.draft? ? 'text-yellow-800' : 'text-blue-800' %>"><%= t("tickets.show.draft_reply") %></h2>
        <% if @ticket.draft_reply_at %>
          <span class="text-xs <%= @ticket.draft? ? 'text-yellow-600' : 'text-blue-600' %>"><%= t("tickets.show.draft_by_agent") %> · <%= l(@ticket.draft_reply_at.in_time_zone(@ticket_timezone), format: :short) %></span>
        <% end %>
      </div>
      <%= form_with(model: @ticket, url: ticket_path(id: @ticket.id), method: :patch, class: "space-y-3") do |f| %>
        <%= f.text_area :draft_reply, rows: 6, placeholder: t("tickets.show.draft_placeholder"),
            class: "w-full px-3 py-2 border #{@ticket.draft? ? 'border-yellow-300' : 'border-blue-300'} rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 #{@ticket.draft? ? 'focus:ring-yellow-500' : 'focus:ring-blue-500'} focus:border-transparent resize-y" %>
        <div class="flex justify-end">
          <%= f.submit t("tickets.show.save_draft"),
              class: "px-4 py-2 #{@ticket.draft? ? 'bg-yellow-600 hover:bg-yellow-700 focus:ring-yellow-500' : 'bg-blue-600 hover:bg-blue-700 focus:ring-blue-500'} text-white text-sm font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Scheduled Send Info (DraftConfirmed) %>
  <% if @ticket.draft_confirmed? %>
    <div class="mt-4 bg-green-50 border border-green-200 rounded-lg p-4">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-green-800"><%= t("tickets.show.draft_reply") %></h2>
          <p class="text-sm text-green-700 mt-1 whitespace-pre-wrap"><%= @ticket.draft_reply %></p>
        </div>
      </div>
      <% if @ticket.scheduled_send_at %>
        <% customer_tz = @ticket.customer&.timezone || "UTC" %>
        <% customer_address = @ticket.customer&.shopify_data&.dig("default_address") %>
        <% customer_location = [customer_address&.dig("province"), customer_address&.dig("country")].compact.join(", ") %>
        <div class="mt-3 space-y-1 text-xs text-green-600">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span><%= t("tickets.show.scheduled_at", time: l(@ticket.scheduled_send_at.in_time_zone(@ticket_timezone), format: :long)) %></span>
            <span class="text-green-500">(<%= @ticket_timezone.name %>)</span>
          </div>
          <div class="flex items-center gap-2 pl-6 text-green-500">
            <span><%= l(@ticket.scheduled_send_at.in_time_zone(customer_tz), format: :long) %></span>
            <span>(<%= customer_tz %><%= " · #{customer_location}" if customer_location.present? %>)</span>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Sent Info (Closed) %>
  <% if @ticket.closed? && @ticket.draft_reply.present? %>
    <div class="mt-4 bg-gray-50 border border-gray-200 rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-4 h-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <h2 class="text-sm font-semibold text-gray-700"><%= t("tickets.show.email_sent") %></h2>
      </div>
      <p class="text-sm text-gray-600 whitespace-pre-wrap"><%= @ticket.draft_reply %></p>
    </div>
  <% end %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Left column: Messages %>
    <div class="lg:col-span-2 flex flex-col">
      <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t("tickets.show.messages") %></h2>

      <% if @messages.any? %>
        <div class="overflow-y-auto space-y-4 pr-2" style="max-height: calc(100vh - 200px);">
        <% @messages.each do |message| %>
          <% is_customer = parse_email_address(message.from)&.downcase != @ticket.email_account.email.downcase %>
          <div>
            <div class="rounded-lg px-4 py-3 <%= is_customer ? 'bg-white border border-gray-200' : 'bg-blue-50 border border-blue-100' %>">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium <%= is_customer ? 'text-gray-700' : 'text-blue-700' %>"><%= message.from %></span>
                <span class="text-xs text-gray-400">
                  <%= message.sent_at ? l(message.sent_at.in_time_zone(@ticket_timezone), format: :short) : "—" %>
                </span>
              </div>
              <%= render_message_body(message.body) %>
            </div>
          </div>
        <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("tickets.show.no_messages") %></p>
      <% end %>
    </div>

    <%# Right column: Desktop only %>
    <div class="hidden lg:block space-y-6 overflow-y-auto" style="max-height: calc(100vh - 200px);">
      <%= render "tickets/info_panel" %>
    </div>
  </div>
</div>
