<div class="max-w-4xl mx-auto" data-controller="customer-search-modal" data-customer-search-modal-url-value="<%= search_customers_ticket_path(id: @ticket.id) %>">
  <%# Header %>
  <div class="flex items-center gap-3">
    <%= link_to tickets_path, class: "text-gray-400 hover:text-gray-600" do %>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-semibold text-gray-900"><%= @ticket.subject || t("tickets.no_subject") %></h1>
      <p class="text-sm text-gray-500">
        <%= @ticket.customer_name || @ticket.customer_email %> &middot;
        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= ticket_status_badge_classes(@ticket.status) %>">
          <%= t("tickets.status.#{@ticket.status}") %>
        </span>
        <% if !@ticket.closed? && @ticket.reopened_reason.present? %>
          <span class="inline-flex items-center gap-1 ml-1 px-2 py-0.5 rounded text-xs font-medium bg-purple-50 text-purple-700">
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
            <%= t("tickets.reopened_reasons.#{@ticket.reopened_reason}") %>
          </span>
        <% end %>
      </p>
    </div>
  </div>

  <%# Status Action Buttons %>
  <% unless @ticket.closed? %>
    <div class="mt-4 flex flex-wrap gap-2">
      <%# new_ticket → draft %>
      <% if @ticket.new_ticket? %>
        <%= render "tickets/status_transition_button",
            ticket: @ticket, target_status: "draft",
            label: t("tickets.show.move_to_draft"),
            color: "yellow", icon: "pencil" %>
      <% end %>

      <%# draft → draft_confirmed %>
      <% if @ticket.draft? %>
        <%= render "tickets/status_transition_button",
            ticket: @ticket, target_status: "draft_confirmed",
            label: t("tickets.show.confirm_schedule"),
            color: "green", icon: "check",
            confirm: t("tickets.show.confirm_schedule_confirm") %>
      <% end %>

      <%# draft_confirmed → draft %>
      <% if @ticket.draft_confirmed? %>
        <%= render "tickets/status_transition_button",
            ticket: @ticket, target_status: "draft",
            label: t("tickets.show.edit_draft"),
            color: "yellow", icon: "pencil" %>
      <% end %>

      <%# draft → new_ticket %>
      <% if @ticket.draft? %>
        <%= render "tickets/status_transition_button",
            ticket: @ticket, target_status: "new_ticket",
            label: t("tickets.show.reset_to_new"),
            color: "blue", icon: "reset" %>
      <% end %>

      <%# new_ticket/draft → closed (two-step confirm) %>
      <% if @ticket.new_ticket? || @ticket.draft? %>
      <%= form_with url: ticket_path(id: @ticket.id), method: :patch, class: "inline" do %>
        <input type="hidden" name="ticket[status]" value="closed" />
        <button type="submit"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white text-sm font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400 cursor-pointer"
                data-controller="confirm-button"
                data-action="click->confirm-button#fire"
                data-confirm-button-confirm-text-value="<%= t("tickets.show.close_confirm_tap") %>">
          <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
          <%= t("tickets.show.close_ticket") %>
        </button>
      <% end %>
      <% end %>
    </div>
  <% end %>

  <%# closed → new_ticket (reopen) %>
  <% if @ticket.closed? %>
    <div class="mt-4 flex flex-wrap gap-2">
      <%= render "tickets/status_transition_button",
          ticket: @ticket, target_status: "new_ticket",
          label: t("tickets.show.reopen_ticket"),
          color: "blue", icon: "reset" %>
    </div>
  <% end %>

  <%# Mobile: Collapsible info panel above messages %>
  <div class="mt-4 lg:hidden" data-controller="collapsible">
    <button data-action="click->collapsible#toggle"
            class="w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-200 shadow-sm text-sm font-medium text-gray-700">
      <span><%= t("tickets.show.details") %></span>
      <svg data-collapsible-target="icon" class="w-4 h-4 text-gray-400 transition-transform" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </button>
    <div data-collapsible-target="content" class="hidden mt-3 space-y-4">
      <%= render "tickets/info_panel" %>
    </div>
  </div>

  <%# Draft Reply Section %>
  <% if @ticket.new_ticket? || @ticket.draft? %>
    <div class="mt-4 <%= @ticket.draft? ? 'bg-yellow-50 border-yellow-200' : 'bg-blue-50 border-blue-200' %> border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold <%= @ticket.draft? ? 'text-yellow-800' : 'text-blue-800' %>"><%= t("tickets.show.draft_reply") %></h2>
        <% if @ticket.draft_reply_at %>
          <span class="text-xs <%= @ticket.draft? ? 'text-yellow-600' : 'text-blue-600' %>"><%= t("tickets.show.draft_by_agent") %> · <%= l(@ticket.draft_reply_at.in_time_zone(@ticket_timezone), format: :short) %></span>
        <% end %>
      </div>
      <%= form_with(model: @ticket, url: ticket_path(id: @ticket.id), method: :patch, class: "space-y-3") do |f| %>
        <%= f.text_area :draft_reply, rows: 6, placeholder: t("tickets.show.draft_placeholder"),
            class: "w-full px-3 py-2 border #{@ticket.draft? ? 'border-yellow-300' : 'border-blue-300'} rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 #{@ticket.draft? ? 'focus:ring-yellow-500' : 'focus:ring-blue-500'} focus:border-transparent resize-y" %>
        <div class="flex justify-end">
          <%= f.submit t("tickets.show.save_draft"),
              class: "px-4 py-2 #{@ticket.draft? ? 'bg-yellow-600 hover:bg-yellow-700 focus:ring-yellow-500' : 'bg-blue-600 hover:bg-blue-700 focus:ring-blue-500'} text-white text-sm font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Agent Instruction (Draft only) %>
  <% if @ticket.draft? %>
    <div class="mt-3 bg-purple-50 border border-purple-200 rounded-lg p-4">
      <h2 class="text-sm font-semibold text-purple-800 mb-2"><%= t("tickets.show.instruct_agent") %></h2>
      <%= form_tag instruct_agent_ticket_path(id: @ticket.id), method: :post, class: "flex gap-2" do %>
        <%= text_field_tag :message, nil, placeholder: t("tickets.show.instruct_agent_placeholder"),
            class: "flex-1 px-3 py-2 border border-purple-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" %>
        <%= submit_tag t("tickets.show.send_to_agent"),
            class: "px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <%# Scheduled Send Info (DraftConfirmed) %>
  <% if @ticket.draft_confirmed? %>
    <div class="mt-4 bg-green-50 border border-green-200 rounded-lg p-4">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-sm font-semibold text-green-800"><%= t("tickets.show.draft_reply") %></h2>
          <p class="text-sm text-green-700 mt-1 whitespace-pre-wrap"><%= @ticket.draft_reply %></p>
        </div>
      </div>
      <% if @ticket.scheduled_send_at %>
        <% customer_tz = @ticket.customer&.timezone || "UTC" %>
        <% customer_address = @ticket.customer&.shopify_data&.dig("default_address") %>
        <% customer_location = [customer_address&.dig("province"), customer_address&.dig("country")].compact.join(", ") %>
        <div class="mt-3 space-y-1 text-xs text-green-600">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span><%= t("tickets.show.scheduled_at", time: l(@ticket.scheduled_send_at.in_time_zone("Asia/Shanghai"), format: :long)) %></span>
            <span class="text-green-500">(UTC+8)</span>
          </div>
          <div class="flex items-center gap-2 pl-6 text-green-500">
            <span><%= l(@ticket.scheduled_send_at.in_time_zone(customer_tz), format: :long) %></span>
            <span>(<%= customer_tz %><%= " · #{customer_location}" if customer_location.present? %>)</span>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Sent Info (Closed) %>
  <% if @ticket.closed? && @ticket.draft_reply.present? %>
    <div class="mt-4 bg-gray-50 border border-gray-200 rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-4 h-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <h2 class="text-sm font-semibold text-gray-700"><%= t("tickets.show.email_sent") %></h2>
      </div>
      <p class="text-sm text-gray-600 whitespace-pre-wrap"><%= @ticket.draft_reply %></p>
    </div>
  <% end %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Left column: Messages %>
    <div class="lg:col-span-2 flex flex-col">
      <h2 class="text-lg font-medium text-gray-900 mb-4"><%= t("tickets.show.messages") %></h2>

      <% if @messages.any? %>
        <div class="overflow-y-auto space-y-4 pr-2" style="max-height: calc(100vh - 200px);">
        <% @messages.each do |message| %>
          <% is_customer = parse_email_address(message.from)&.downcase != @ticket.email_account.email.downcase %>
          <div>
            <div class="rounded-lg px-4 py-3 <%= is_customer ? 'bg-white border border-gray-200' : 'bg-blue-50 border border-blue-100' %>">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium <%= is_customer ? 'text-gray-700' : 'text-blue-700' %>"><%= message.from %></span>
                <span class="text-xs text-gray-400">
                  <%= message.sent_at ? l(message.sent_at.in_time_zone(@ticket_timezone), format: :short) : "—" %>
                </span>
              </div>
              <%= render_message_body(message.body) %>
            </div>
          </div>
        <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("tickets.show.no_messages") %></p>
      <% end %>
    </div>

    <%# Right column: Desktop only %>
    <div class="hidden lg:block space-y-6 overflow-y-auto" style="max-height: calc(100vh - 200px);">
      <%= render "tickets/info_panel" %>
    </div>
  </div>

  <%# Customer Search Modal %>
  <div data-customer-search-modal-target="modal" class="hidden fixed inset-0 z-50">
    <div data-customer-search-modal-target="backdrop"
         data-action="click->customer-search-modal#backdropClick"
         class="fixed inset-0 bg-black/50 transition-opacity">
    </div>
    <div class="fixed inset-0 flex items-start justify-center pt-[15vh] px-4">
      <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden">
        <%# Modal header %>
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
          <h3 class="text-base font-semibold text-gray-900"><%= t("tickets.show.search_customer_title") %></h3>
          <button type="button" data-action="click->customer-search-modal#close" class="text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <%# Search input %>
        <div class="px-5 py-3 border-b border-gray-100">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
            <input type="text"
                   data-customer-search-modal-target="input"
                   data-action="input->customer-search-modal#search"
                   placeholder="<%= t("tickets.show.search_customer_placeholder") %>"
                   class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
        </div>

        <%# Results %>
        <div class="max-h-72 overflow-y-auto">
          <div data-customer-search-modal-target="loading" class="hidden px-5 py-4 text-center">
            <span class="text-sm text-gray-500"><%= t("tickets.show.searching") %></span>
          </div>
          <div data-customer-search-modal-target="results"></div>
          <div data-customer-search-modal-target="empty" class="hidden px-5 py-4 text-center">
            <p class="text-sm text-gray-500"><%= t("tickets.show.no_results") %></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Hidden form for linking customer %>
  <%= form_tag link_customer_ticket_path(id: @ticket.id), method: :patch, id: "link-customer-form" do %>
    <input type="hidden" name="customer_id" value="" />
  <% end %>
</div>
