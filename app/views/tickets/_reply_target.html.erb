<div class="mb-3">
  <p class="text-xs text-gray-500 mb-1.5"><%= t("tickets.show.reply_method") %></p>
  <div class="inline-flex bg-gray-100 rounded-lg p-1 text-xs">
    <button type="button" data-action="reply-target#useCurrent" data-reply-target-target="currentBtn"
            class="px-3 py-1.5 rounded-md font-medium bg-white text-gray-900 shadow-sm">↩︎ <%= t("tickets.show.reply_current") %></button>
    <button type="button" data-action="reply-target#useNew" data-reply-target-target="newBtn"
            class="px-3 py-1.5 rounded-md font-medium text-gray-500">＋ <%= t("tickets.show.reply_new") %></button>
  </div>
  <div data-reply-target-target="newFields" class="hidden mt-2 space-y-2">
    <input type="text" name="ticket[subject]" placeholder="<%= t("tickets.show.new_thread_subject") %>"
           class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" />
  </div>
</div>
