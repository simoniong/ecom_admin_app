<%# Customer Info %>
<div class="bg-white shadow-sm rounded-lg border border-gray-200 p-4">
  <h3 class="text-sm font-semibold text-gray-900 mb-3"><%= t("tickets.show.customer") %></h3>
  <% if @customer %>
    <dl class="space-y-2 text-sm">
      <% if @customer.full_name %>
        <div>
          <dt class="text-gray-500"><%= t("tickets.show.customer_name") %></dt>
          <dd class="text-gray-900"><%= @customer.full_name %></dd>
        </div>
      <% end %>
      <div>
        <dt class="text-gray-500"><%= t("tickets.show.customer_email") %></dt>
        <dd class="text-gray-900"><%= @customer.email || @ticket.customer_email %></dd>
      </div>
      <% if @customer.phone.present? %>
        <div>
          <dt class="text-gray-500"><%= t("tickets.show.customer_phone") %></dt>
          <dd class="text-gray-900"><%= @customer.phone %></dd>
        </div>
      <% end %>
    </dl>
  <% else %>
    <p class="text-sm text-gray-500"><%= @ticket.customer_email %></p>
    <p class="text-xs text-gray-400 mt-1"><%= t("tickets.show.no_shopify_customer") %></p>
  <% end %>
</div>

<%# Orders & Fulfillments %>
<% if @orders.any? %>
  <% @orders.each do |order| %>
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-4">
      <%# Order header %>
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-gray-900"><%= order.name %></span>
        <span class="text-xs text-gray-500"><%= order.ordered_at ? l(order.ordered_at.in_time_zone("Asia/Shanghai"), format: :short) : "—" %></span>
      </div>
      <div class="flex items-center gap-2 mb-1">
        <span class="text-sm text-gray-700"><%= number_to_currency(order.total_price, unit: order.currency.to_s + " ") %></span>
        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700"><%= order.financial_status %></span>
      </div>
      <dl class="text-xs text-gray-500 space-y-0.5 mb-3">
        <% if order.ordered_at %>
          <div class="flex justify-between">
            <dt><%= t("tickets.show.paid_at") %></dt>
            <dd class="text-gray-700"><%= l(order.ordered_at.in_time_zone("Asia/Shanghai"), format: :short) %></dd>
          </div>
        <% end %>
        <% if order.fulfillment_status.present? %>
          <div class="flex justify-between">
            <dt><%= t("tickets.show.fulfillment_status") %></dt>
            <dd class="text-gray-700"><%= order.fulfillment_status == "fulfilled" ? t("tickets.show.fulfillment_fulfilled") : order.fulfillment_status.humanize %></dd>
          </div>
        <% end %>
      </dl>

      <%# Fulfillment cards %>
      <% if order.fulfillments.any? %>
        <div class="space-y-3">
          <% order.fulfillments.each do |f| %>
            <div class="border border-gray-100 rounded-lg overflow-hidden" data-controller="collapsible">
              <%# Fulfillment summary — clickable to expand %>
              <button data-action="click->collapsible#toggle"
                      class="w-full text-left px-3 py-2.5 hover:bg-gray-50 transition">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= f.status_badge_classes %>"><%= f.tracking_status_display.presence || f.status&.humanize %></span>
                    <% if f.tracking_number.present? %>
                      <span class="text-xs font-mono text-gray-600"><%= f.tracking_number %></span>
                    <% end %>
                  </div>
                  <svg data-collapsible-target="icon" class="w-4 h-4 text-gray-400 transition-transform shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                </div>

                <div class="flex items-center gap-3 mt-1">
                  <% if f.tracking_company.present? %>
                    <span class="text-xs text-gray-400"><%= f.tracking_company %></span>
                  <% end %>
                  <% if f.shipped_at.present? %>
                    <span class="text-xs text-gray-400"><%= t("tickets.show.shipped_at") %> <%= l(f.shipped_at.in_time_zone("Asia/Shanghai"), format: :short) %></span>
                  <% end %>
                </div>

                <%# Last tracking event preview %>
                <% if f.last_tracking_event.present? %>
                  <div class="mt-2 flex items-start gap-2">
                    <div class="mt-0.5 w-2 h-2 rounded-full bg-green-500 shrink-0"></div>
                    <div>
                      <p class="text-xs text-gray-700"><%= f.last_tracking_event %></p>
                      <% if f.last_tracking_time.present? %>
                        <p class="text-xs text-gray-400"><%= f.last_tracking_time %></p>
                      <% end %>
                    </div>
                  </div>
                <% elsif f.tracking_loaded? %>
                  <p class="text-xs text-gray-400 mt-1"><%= t("tickets.show.no_tracking_events") %></p>
                <% else %>
                  <p class="text-xs text-gray-400 mt-1"><%= t("tickets.show.tracking_pending") %></p>
                <% end %>
              </button>

              <%# Expanded: full tracking timeline %>
              <div data-collapsible-target="content" class="hidden border-t border-gray-100 px-3 py-3 bg-gray-50">
                <% if f.tracking_url.present? %>
                  <div class="mb-3">
                    <%= link_to t("tickets.show.view_on_carrier"), f.tracking_url, target: "_blank", rel: "noopener",
                        class: "text-xs text-blue-600 hover:underline" %>
                  </div>
                <% end %>

                <% events = f.tracking_events %>
                <% if events.any? %>
                  <div class="relative pl-4">
                    <div class="absolute left-1.5 top-1 bottom-1 w-px bg-gray-200"></div>
                    <% events.each_with_index do |event, i| %>
                      <div class="relative pb-3 last:pb-0">
                        <div class="absolute -left-2.5 mt-1 w-2 h-2 rounded-full <%= i == 0 ? 'bg-green-500' : 'bg-gray-300' %>"></div>
                        <div class="ml-2">
                          <p class="text-xs text-gray-800"><%= event["description"] %></p>
                          <div class="flex items-center gap-2 mt-0.5">
                            <% if event["time"].present? %>
                              <span class="text-xs text-gray-400"><%= event["time"] %></span>
                            <% end %>
                            <% if event["location"].present? %>
                              <span class="text-xs text-gray-400"><%= event["location"] %></span>
                            <% end %>
                          </div>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="text-xs text-gray-500"><%= t("tickets.show.no_tracking_events") %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-4">
    <h3 class="text-sm font-semibold text-gray-900 mb-3"><%= t("tickets.show.orders") %></h3>
    <p class="text-sm text-gray-500"><%= t("tickets.show.no_orders") %></p>
  </div>
<% end %>
