<div data-controller="order-picker"
     data-order-picker-url-value="<%= search_orders_ticket_path(id: @ticket.id) %>"
     data-order-picker-clear-label="<%= t("tickets.show.order_none") %>">
  <button type="button" data-action="click->order-picker#open" class="hidden" data-ticket-order-open></button>

  <div data-order-picker-target="modal" class="hidden fixed inset-0 z-50">
    <div data-order-picker-target="backdrop" data-action="click->order-picker#backdropClick"
         class="fixed inset-0 bg-black/50"></div>
    <div class="fixed inset-0 flex items-start justify-center pt-[12vh] px-4">
      <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
          <h3 class="text-base font-semibold text-gray-900"><%= t("tickets.show.bind_order_title") %></h3>
          <button type="button" data-action="click->order-picker#close" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <div class="px-5 py-3 border-b border-gray-100">
          <input type="text" data-order-picker-target="input" data-action="input->order-picker#search"
                 placeholder="<%= t("tickets.show.bind_order_search_placeholder") %>"
                 class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <p class="text-[11px] text-gray-400 mt-1.5"><%= t("tickets.show.bind_order_hint") %></p>
        </div>
        <div data-order-picker-target="results" class="max-h-80 overflow-y-auto divide-y divide-gray-100"></div>
      </div>
    </div>
  </div>

  <%= form_with url: bind_order_ticket_path(id: @ticket.id), method: :patch,
                data: { order_picker_target: "form" }, class: "hidden" do %>
    <input type="hidden" name="order_id" data-order-picker-target="orderId" />
  <% end %>
</div>
