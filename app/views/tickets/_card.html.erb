<div class="bg-white rounded-lg border border-gray-200 shadow-sm p-3 cursor-grab active:cursor-grabbing"
     data-ticket-id="<%= ticket.id %>">
  <%= link_to ticket_path(ticket), class: "block" do %>
    <p class="text-sm font-medium text-gray-900 truncate"><%= ticket.subject || t("tickets.no_subject") %></p>
    <p class="text-xs text-gray-500 mt-1 truncate">
      <% if ticket.customer_name.present? %>
        <%= ticket.customer_name %>
      <% else %>
        <%= ticket.customer_email %>
      <% end %>
    </p>
    <% if !ticket.closed? && ticket.reopened_reason.present? %>
      <span class="inline-flex items-center gap-1 mt-1.5 px-1.5 py-0.5 rounded text-xs font-medium bg-purple-50 text-purple-700">
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
        </svg>
        <%= t("tickets.reopened_reasons.#{ticket.reopened_reason}") %>
      </span>
    <% end %>
    <div class="flex items-center justify-between mt-2">
      <span class="text-xs text-gray-400">
        <%= ticket.last_message_at ? l(ticket.last_message_at.in_time_zone("Asia/Shanghai"), format: :short) : "—" %>
      </span>
      <div class="flex items-center gap-1">
        <% if ticket.scheduled_send_at %>
          <svg class="w-3.5 h-3.5 text-green-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        <% elsif ticket.draft_reply.present? %>
          <svg class="w-3.5 h-3.5 text-yellow-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
          </svg>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
