<h2 class="text-2xl font-semibold text-gray-900 text-center mb-2"><%= t("invitations.accept_title") %></h2>
<p class="text-sm text-gray-600 text-center mb-6">
  <%= t("invitations.accept_description", company: @invitation.company.name) %>
</p>

<div class="mb-6 bg-gray-50 rounded-md p-4 space-y-2">
  <div class="flex justify-between text-sm">
    <span class="text-gray-500"><%= t("invitations.company_label") %></span>
    <span class="font-medium text-gray-900"><%= @invitation.company.name %></span>
  </div>
  <div class="flex justify-between text-sm">
    <span class="text-gray-500"><%= t("invitations.role") %></span>
    <span class="font-medium text-gray-900"><%= t("invitations.roles.#{@invitation.role}") %></span>
  </div>
</div>

<% if @state == :accept %>
  <%# User is already signed in — just accept %>
  <p class="text-sm text-gray-600 mb-4 text-center">
    <%= t("invitations.signed_in_as", email: current_user.email) %>
  </p>
  <%= button_to accept_invitation_confirm_path(token: @invitation.token),
      class: "w-full bg-gray-900 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 cursor-pointer" do %>
    <%= t("invitations.accept_button") %>
  <% end %>

<% elsif @state == :login %>
  <%# User has an account — ask them to log in %>
  <p class="text-sm text-gray-600 mb-4 text-center">
    <%= t("invitations.login_prompt", email: @invitation.email) %>
  </p>
  <%= form_tag accept_invitation_confirm_path(token: @invitation.token), method: :post, data: { turbo: false } do %>
    <%= hidden_field_tag :state, "login" %>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t("profile.email") %></label>
        <p class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-500"><%= @invitation.email %></p>
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1"><%= t("auth.password", default: "Password") %></label>
        <%= password_field_tag :password, nil, autocomplete: "current-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
      </div>
      <div>
        <%= submit_tag t("invitations.login_and_accept"),
            class: "w-full bg-gray-900 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 cursor-pointer" %>
      </div>
    </div>
  <% end %>

<% elsif @state == :register %>
  <%# New user — register and accept %>
  <p class="text-sm text-gray-600 mb-4 text-center">
    <%= t("invitations.register_prompt") %>
  </p>
  <%= form_tag accept_invitation_confirm_path(token: @invitation.token), method: :post, data: { turbo: false } do %>
    <%= hidden_field_tag :state, "register" %>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= t("profile.email") %></label>
        <p class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-md text-sm text-gray-500"><%= @invitation.email %></p>
      </div>
      <% if @user.errors.any? %>
        <div class="p-3 bg-red-50 border border-red-200 text-red-700 rounded-md text-sm">
          <ul class="list-disc list-inside">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div>
        <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1"><%= t("profile.first_name") %></label>
        <%= text_field_tag :first_name, params[:first_name],
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
      </div>
      <div>
        <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1"><%= t("profile.last_name") %></label>
        <%= text_field_tag :last_name, params[:last_name],
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1"><%= t("invitations.create_password") %></label>
        <%= password_field_tag :password, nil, autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
      </div>
      <div>
        <label for="password_confirmation" class="block text-sm font-medium text-gray-700 mb-1"><%= t("profile.confirm_password") %></label>
        <%= password_field_tag :password_confirmation, nil, autocomplete: "new-password",
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
      </div>
      <div>
        <%= submit_tag t("invitations.register_and_accept"),
            class: "w-full bg-gray-900 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 cursor-pointer" %>
      </div>
    </div>
  <% end %>
<% end %>
