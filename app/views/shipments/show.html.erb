<div class="max-w-5xl mx-auto">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to shipments_path, class: "text-gray-400 hover:text-gray-600", aria: { label: t("shipments.show.back") } do %>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      <% end %>
      <div>
        <h1 class="text-2xl font-semibold text-gray-900 font-mono"><%= @fulfillment.tracking_number %></h1>
        <p class="text-sm text-gray-500"><%= t("shipments.show.carrier_label", carrier: @fulfillment.tracking_company.presence || "—") %></p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <% if @fulfillment.archived_at.present? %>
        <%= button_to unarchive_shipment_path(id: @fulfillment.id), method: :post,
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors" do %>
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5m6 4.125 2.25 2.25m0 0 2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
          </svg>
          <%= t("shipments.show.archived") %>
        <% end %>
      <% else %>
        <%= button_to archive_shipment_path(id: @fulfillment.id), method: :post,
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
          </svg>
          <%= t("shipments.show.archive_btn") %>
        <% end %>
      <% end %>
      <button data-controller="clipboard"
              data-clipboard-text-value="<%= @fulfillment.tracking_number %>"
              data-clipboard-success-message-value="<%= t("shipments.show.copied") %>"
              data-action="click->clipboard#copy"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
        </svg>
        <%= t("shipments.show.copy_tracking_number") %>
      </button>
      <% if @fulfillment.tracking_url.present? %>
        <button data-controller="clipboard"
                data-clipboard-text-value="<%= @fulfillment.tracking_url %>"
                data-clipboard-success-message-value="<%= t("shipments.show.copied") %>"
                data-action="click->clipboard#copy"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
          </svg>
          <%= t("shipments.show.copy_tracking_link") %>
        </button>
      <% end %>
    </div>
  </div>

  <%# Mobile: Collapsible sidebar %>
  <div class="mt-4 lg:hidden" data-controller="collapsible">
    <button data-action="click->collapsible#toggle"
            class="w-full flex items-center justify-between px-4 py-3 bg-white rounded-lg border border-gray-200 shadow-sm text-sm font-medium text-gray-700">
      <span><%= t("shipments.show.order") %></span>
      <svg data-collapsible-target="icon" class="w-4 h-4 text-gray-400 transition-transform" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </button>
    <div data-collapsible-target="content" class="hidden mt-3 space-y-4">
      <%= render "shipments/sidebar" %>
    </div>
  </div>

  <%# Two-column layout %>
  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Left column — Status + Timeline %>
    <div class="lg:col-span-2 space-y-4">
      <%# Status summary card %>
      <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-5">
        <div class="flex items-start gap-4">
          <%# Status icon %>
          <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center
                      <% if @fulfillment.tracking_status == 'Delivered' %>bg-green-100<% elsif @fulfillment.tracking_status == 'Exception' || @fulfillment.tracking_status == 'DeliveryFailure' %>bg-red-100<% else %>bg-blue-100<% end %>">
            <% if @fulfillment.tracking_status == "Delivered" %>
              <svg class="w-5 h-5 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            <% elsif @fulfillment.tracking_status == "Exception" || @fulfillment.tracking_status == "DeliveryFailure" %>
              <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
              </svg>
            <% else %>
              <svg class="w-5 h-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            <% end %>
          </div>

          <div class="flex-1">
            <%# Status badge + carrier route %>
            <div class="flex items-center gap-2 flex-wrap">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium <%= @fulfillment.status_badge_classes %>">
                <span class="w-1.5 h-1.5 rounded-full <%= @fulfillment.status_dot_class %>"></span>
                <%= @fulfillment.tracking_status_display %>
              </span>
              <% if @fulfillment.origin_country.present? || @fulfillment.destination_country.present? %>
                <span class="text-sm text-gray-500">
                  <%= t("shipments.show.carrier_route",
                      origin: @fulfillment.origin_country.presence || "—",
                      destination: @fulfillment.destination_country.presence || "—") %>
                </span>
              <% end %>
            </div>

            <%# Sub-status %>
            <% if @fulfillment.tracking_sub_status.present? %>
              <p class="mt-1 text-sm text-gray-700">
                <%= @fulfillment.tracking_sub_status.gsub(/([a-z])([A-Z])/, '\1 \2').gsub("_", " ") %>
              </p>
            <% end %>

            <%# Latest event description %>
            <% if @fulfillment.latest_event_description.present? %>
              <p class="mt-1 text-sm text-gray-500"><%= @fulfillment.latest_event_description %></p>
            <% end %>

            <%# Transit / delivery info %>
            <div class="mt-2 flex flex-wrap gap-4 text-sm text-gray-500">
              <% if @fulfillment.transit_days.present? %>
                <span><%= t("shipments.show.in_transit_days", count: @fulfillment.transit_days) %></span>
              <% end %>
              <% if @fulfillment.shipped_at.present? %>
                <span><%= t("shipments.show.shipped_at") %>: <%= @fulfillment.shipped_at.in_time_zone(@tz).strftime("%-d %b, %Y %H:%M") %></span>
              <% end %>
              <% if @fulfillment.delivered_at.present? %>
                <span><%= t("shipments.show.delivered_at") %>: <%= @fulfillment.delivered_at.in_time_zone(@tz).strftime("%-d %b, %Y %H:%M") %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <%# Tracking timeline %>
      <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-900"><%= t("shipments.show.tracking_details") %></h3>
          <% if @tracking_url.present? %>
            <%= link_to t("shipments.show.view_on_carrier"), @tracking_url,
                target: "_blank", rel: "noopener",
                class: "text-sm text-blue-600 hover:underline" %>
          <% end %>
        </div>

        <% if @events.any? %>
          <%# Carrier badge %>
          <% carrier_name = @fulfillment.destination_carrier.presence || @fulfillment.origin_carrier.presence || @fulfillment.tracking_company %>
          <% if carrier_name.present? %>
            <div class="mb-4 flex items-center gap-2 text-sm text-gray-600">
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
              <span class="font-medium"><%= carrier_name %></span>
            </div>
          <% end %>

          <%# Timeline %>
          <div class="relative">
            <% @events.each_with_index do |event, index| %>
              <div class="flex gap-4 <%= "pb-6" unless index == @events.length - 1 %>">
                <%# Timeline dot + line %>
                <div class="relative flex flex-col items-center">
                  <div class="w-3 h-3 rounded-full border-2 flex-shrink-0
                              <%= index == 0 ? "bg-blue-500 border-blue-500" : "bg-white border-gray-300" %>"></div>
                  <% unless index == @events.length - 1 %>
                    <div class="w-px flex-1 bg-gray-200 mt-1"></div>
                  <% end %>
                </div>

                <%# Event content %>
                <div class="flex-1 -mt-0.5">
                  <p class="text-sm <%= index == 0 ? "text-gray-900 font-medium" : "text-gray-700" %>">
                    <%= event["description"] %>
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5">
                    <% if event["time"].present? %>
                      <%= Time.zone.parse(event["time"]).in_time_zone(@tz).strftime("%-d %b, %Y %H:%M:%S") rescue event["time"] %>
                    <% end %>
                    <% if event["location"].present? %>
                      <% if event["time"].present? %> &middot; <% end %>
                      <%= event["location"] %>
                    <% end %>
                  </p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500"><%= t("shipments.show.no_tracking") %></p>
        <% end %>
      </div>
    </div>

    <%# Right column — Sidebar (desktop) %>
    <div class="hidden lg:block space-y-4">
      <%= render "shipments/sidebar" %>
    </div>
  </div>
</div>
