<div class="space-y-4" data-controller="shipment-filter" data-action="click@window->shipment-filter#closeSortDropdown">
  <%# Header %>
  <div class="flex items-center justify-between">
    <div class="relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle" aria-haspopup="true" aria-expanded="false" data-dropdown-target="button"
              class="flex items-center gap-1 text-2xl font-bold text-gray-900 hover:text-gray-700">
        <%= @archived ? t("shipments.archived_title") : t("shipments.title") %>
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
      <div data-dropdown-target="menu" role="menu" class="hidden absolute left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-200 z-20 py-1">
        <%= link_to shipments_path,
            class: "flex items-center justify-between w-full px-4 py-2 text-sm hover:bg-gray-50 #{"font-medium" unless @archived}" do %>
          <%= t("shipments.title") %>
          <% unless @archived %>
            <svg class="w-4 h-4 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
          <% end %>
        <% end %>
        <%= link_to shipments_path(archived: "true"),
            class: "flex items-center justify-between w-full px-4 py-2 text-sm hover:bg-gray-50 #{"font-medium" if @archived}" do %>
          <%= t("shipments.archived_title") %>
          <% if @archived %>
            <svg class="w-4 h-4 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
          <% end %>
        <% end %>
      </div>
    </div>
    <%= button_to sync_shipments_path, method: :post,
        class: "inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-gray-900 rounded-md hover:bg-gray-800" do %>
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182M2.985 14.652" />
      </svg>
      <%= t("shipments.sync_orders") %>
    <% end %>
  </div>

  <%# Form wrapping all filters %>
  <%= form_tag shipments_path, method: :get, data: { shipment_filter_target: "filterForm" }, class: "space-y-4" do %>
    <% if @archived %><input type="hidden" name="archived" value="true"><% end %>
    <input type="hidden" name="status_tab" value="<%= @status_tab || 'All' %>" data-shipment-filter-target="statusTab">
    <input type="hidden" name="sort_field" value="<%= @sort_field %>" data-shipment-filter-target="sortField">
    <input type="hidden" name="sort_direction" value="<%= @sort_direction %>" data-shipment-filter-target="sortDirection">

    <%# Status tabs %>
    <div class="flex flex-wrap gap-1 bg-white rounded-lg border border-gray-200 p-2">
      <% status_tabs = [["All", @status_counts["All"]]] + Fulfillment::TRACKING_STATUSES.map { |s| [s, @status_counts[s] || 0] } %>
      <% status_tabs.each do |status, count| %>
        <button type="button"
                data-action="click->shipment-filter#selectTab"
                data-status="<%= status %>"
                class="px-3 py-1.5 text-sm font-medium rounded-md whitespace-nowrap transition-colors
                       <%= (@status_tab || 'All') == status ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-100' %>">
          <%= Fulfillment::STATUS_DISPLAY_NAMES[status] || status %> (<%= count %>)
        </button>
      <% end %>
    </div>

    <%# Search + Filter dropdowns + Sort + Column toggle %>
    <div class="flex flex-wrap items-center gap-3">
      <%# Search %>
      <div class="flex-1 min-w-[250px]">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input type="text" name="search" value="<%= @search %>"
                 placeholder="<%= t("shipments.search_placeholder") %>"
                 data-shipment-filter-target="searchInput"
                 data-action="keydown->shipment-filter#submitOnEnter"
                 class="block w-full pl-10 pr-3 py-2 rounded-md border border-gray-300 shadow-sm text-sm focus:border-blue-500 focus:ring-blue-500">
        </div>
      </div>

      <%# Status dropdown %>
      <div class="relative">
        <select name="status" data-action="change->shipment-filter#filterChanged"
                class="appearance-none pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
          <option value=""><%= t("shipments.filters.status") %></option>
          <% Fulfillment::TRACKING_STATUSES.each do |s| %>
            <option value="<%= s %>" <%= "selected" if @status_filter == s %>><%= Fulfillment::STATUS_DISPLAY_NAMES[s] || s %></option>
          <% end %>
        </select>
        <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </div>

      <%# Destination dropdown %>
      <div class="relative">
        <select name="destination" data-action="change->shipment-filter#filterChanged"
                class="appearance-none pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
          <option value=""><%= t("shipments.filters.destination") %></option>
          <% @destinations.each do |country| %>
            <option value="<%= country %>" <%= "selected" if @destination == country %>><%= country %></option>
          <% end %>
        </select>
        <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </div>

      <%# Origin carrier dropdown %>
      <div class="relative">
        <select name="origin_carrier" data-action="change->shipment-filter#filterChanged"
                class="appearance-none pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
          <option value=""><%= t("shipments.filters.origin_carrier") %></option>
          <% @origin_carriers.each do |carrier| %>
            <option value="<%= carrier %>" <%= "selected" if @origin_carrier_filter == carrier %>><%= carrier %></option>
          <% end %>
        </select>
        <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </div>

      <%# More filters toggle %>
      <button type="button" data-action="click->shipment-filter#toggleMoreFilters"
              class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
        <%= t("shipments.filters.more_filters") %>
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </button>

      <%# Sort dropdown %>
      <div class="relative">
        <button type="button" data-action="click->shipment-filter#toggleSortDropdown"
                class="inline-flex items-center p-2 text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />
          </svg>
        </button>
        <div data-shipment-filter-target="sortDropdown" class="hidden absolute right-0 mt-2 w-64 bg-white rounded-lg shadow-lg border border-gray-200 z-20 py-2">
          <% sort_fields = [
            ["input_time", t("shipments.sort.input_time")],
            ["order_time", t("shipments.sort.order_time")],
            ["latest_event_update_time", t("shipments.sort.latest_event_update_time")],
            ["shipping_time", t("shipments.sort.shipping_time")],
            ["transit_time", t("shipments.sort.transit_time")]
          ] %>
          <% sort_fields.each do |field, label| %>
            <button type="button" data-action="click->shipment-filter#selectSortField" data-sort-field="<%= field %>"
                    class="flex items-center w-full px-4 py-2 text-sm hover:bg-gray-50">
              <span class="w-5 h-5 mr-3 flex items-center justify-center">
                <% if @sort_field == field %>
                  <span class="w-4 h-4 rounded-full border-4 border-gray-900"></span>
                <% else %>
                  <span class="w-4 h-4 rounded-full border-2 border-gray-300"></span>
                <% end %>
              </span>
              <%= label %>
            </button>
          <% end %>
          <div class="border-t border-gray-200 mt-1 pt-1">
            <button type="button" data-action="click->shipment-filter#selectSortDirection" data-sort-direction="asc"
                    class="flex items-center w-full px-4 py-2 text-sm hover:bg-gray-50 <%= @sort_direction == 'asc' ? 'bg-gray-100 font-medium' : '' %>">
              <svg class="w-4 h-4 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
              </svg>
              <%= t("shipments.sort.oldest_to_newest") %>
            </button>
            <button type="button" data-action="click->shipment-filter#selectSortDirection" data-sort-direction="desc"
                    class="flex items-center w-full px-4 py-2 text-sm hover:bg-gray-50 <%= @sort_direction == 'desc' ? 'bg-gray-100 font-medium' : '' %>">
              <svg class="w-4 h-4 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
              </svg>
              <%= t("shipments.sort.newest_to_oldest") %>
            </button>
          </div>
        </div>
      </div>

      <%# Column toggle %>
      <div class="relative" data-controller="column-toggle" data-action="click@window->column-toggle#close">
        <button type="button" data-action="click->column-toggle#toggle"
                class="inline-flex items-center p-2 text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z" />
          </svg>
        </button>
        <div data-column-toggle-target="dropdown" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 z-20 py-2 max-h-80 overflow-y-auto">
          <%
            toggleable_columns = [
              ["order_info", t("shipments.columns.order_info"), true],
              ["status", t("shipments.columns.status"), true],
              ["sub_status", t("shipments.columns.sub_status"), true],
              ["latest_event", t("shipments.columns.latest_event"), true],
              ["origin_carrier", t("shipments.columns.origin_carrier"), true],
              ["destination_carrier", t("shipments.columns.destination_carrier"), true],
              ["destination", t("shipments.columns.destination"), true],
              ["transit_time", t("shipments.columns.transit_time"), true],
              ["tags", t("shipments.columns.tags"), false],
              ["shop_name", t("shipments.columns.shop_name"), true],
              ["origin", t("shipments.columns.origin"), false],
              ["input_time", t("shipments.columns.input_time"), false],
              ["ordered_time", t("shipments.columns.ordered_time"), false],
              ["shipping_time", t("shipments.columns.shipping_time"), false],
              ["shopify_order_tag", t("shipments.columns.shopify_order_tag"), false],
              ["latest_event_update_time", t("shipments.columns.latest_event_update_time"), false],
              ["order_amount", t("shipments.columns.order_amount"), false],
              ["customer_name", t("shipments.columns.customer_name"), false],
              ["customer_email", t("shipments.columns.customer_email"), false]
            ]
          %>
          <div data-column-toggle-target="list">
            <% toggleable_columns.each do |col_id, label, default_visible| %>
              <div class="flex items-center px-4 py-1.5 text-sm hover:bg-gray-50"
                   data-column-toggle-target="item" data-column="<%= col_id %>">
                <span data-drag-handle class="cursor-grab text-gray-400 mr-2 select-none" title="Drag to reorder">&#10495;</span>
                <input id="column-toggle-<%= col_id %>" type="checkbox" data-column-toggle-target="checkbox" data-column="<%= col_id %>"
                       data-action="change->column-toggle#columnChanged"
                       <%= "checked" if default_visible %>
                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-3">
                <label for="column-toggle-<%= col_id %>" class="cursor-pointer"><%= label %></label>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# More filters panel (hidden by default) %>
    <div data-shipment-filter-target="moreFilters" class="hidden bg-white rounded-lg border border-gray-200 p-4">
      <div class="flex flex-wrap gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1"><%= t("shipments.filters.destination_carrier") %></label>
          <div class="relative">
            <select name="destination_carrier" data-action="change->shipment-filter#filterChanged"
                    class="appearance-none w-40 pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
              <option value=""><%= t("shipments.all") %></option>
              <% @destination_carriers.each do |carrier| %>
                <option value="<%= carrier %>" <%= "selected" if @destination_carrier_filter == carrier %>><%= carrier %></option>
              <% end %>
            </select>
            <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>

        <%# Latest event update time range %>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1"><%= t("shipments.filters.event_time") %></label>
          <div class="flex items-center gap-2">
            <input type="date" name="event_from" value="<%= @event_from %>"
                   data-action="change->shipment-filter#filterChanged"
                   class="w-36 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
            <span class="text-gray-400 text-sm">–</span>
            <input type="date" name="event_to" value="<%= @event_to %>"
                   data-action="change->shipment-filter#filterChanged"
                   class="w-36 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
          </div>
        </div>

        <%# Shipped time range %>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1"><%= t("shipments.filters.shipped_time") %></label>
          <div class="flex items-center gap-2">
            <input type="date" name="shipped_from" value="<%= @shipped_from %>"
                   data-action="change->shipment-filter#filterChanged"
                   class="w-36 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
            <span class="text-gray-400 text-sm">–</span>
            <input type="date" name="shipped_to" value="<%= @shipped_to %>"
                   data-action="change->shipment-filter#filterChanged"
                   class="w-36 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
          </div>
        </div>

        <%# Transit time range (days) %>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1"><%= t("shipments.filters.transit_days") %></label>
          <div class="flex items-center gap-2">
            <input type="number" name="transit_min" value="<%= @transit_min %>" min="0" placeholder="<%= t("shipments.filters.min") %>"
                   data-action="change->shipment-filter#filterChanged"
                   class="w-20 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
            <span class="text-gray-400 text-sm">–</span>
            <input type="number" name="transit_max" value="<%= @transit_max %>" min="0" placeholder="<%= t("shipments.filters.max") %>"
                   data-action="change->shipment-filter#filterChanged"
                   class="w-20 px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500">
            <span class="text-xs text-gray-400"><%= t("shipments.filters.days") %></span>
          </div>
        </div>

        <%# Tag filter (dropdown with checkboxes, OR logic) %>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1"><%= t("shipments.filters.tag") %></label>
          <div class="relative" data-controller="dropdown">
            <button type="button" data-action="click->dropdown#toggle" aria-haspopup="true" aria-expanded="false" data-dropdown-target="button"
                    class="inline-flex items-center justify-between w-48 pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 hover:bg-gray-50 cursor-pointer">
              <span class="truncate">
                <% if @tag_filters&.any? %>
                  <%= @tag_filters.join(", ") %>
                <% else %>
                  <%= t("shipments.all") %>
                <% end %>
              </span>
              <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div data-dropdown-target="menu" role="menu" class="hidden absolute left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-200 z-20">
              <div class="py-2 max-h-48 overflow-y-auto">
                <% @available_tags.each do |tag| %>
                  <label class="flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-gray-50 cursor-pointer">
                    <input type="checkbox" name="tags[]" value="<%= tag %>"
                           <%= "checked" if @tag_filters&.include?(tag) %>
                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                    <span class="text-gray-700"><%= tag %></span>
                  </label>
                <% end %>
                <% if @available_tags.empty? %>
                  <p class="px-3 py-2 text-sm text-gray-500"><%= t("shipments.tags.no_tags") %></p>
                <% end %>
              </div>
              <% if @available_tags.any? %>
                <div class="flex items-center justify-between px-3 py-2 border-t border-gray-200">
                  <button type="button" data-action="click->shipment-filter#clearTagFilter"
                          class="text-sm text-blue-600 hover:text-blue-800"><%= t("shipments.clear_all") %></button>
                  <button type="button" data-action="click->shipment-filter#filterChanged"
                          class="px-3 py-1 text-sm font-medium text-white bg-gray-900 rounded-md hover:bg-gray-800"><%= t("shipments.tags.apply") %></button>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <% if @stores.count > 1 %>
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1"><%= t("shipments.filters.store") %></label>
            <div class="relative">
              <select name="store_id" data-action="change->shipment-filter#filterChanged"
                      class="appearance-none w-48 pl-3 pr-8 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-blue-500 focus:ring-blue-500 cursor-pointer">
                <option value=""><%= t("shipments.all") %></option>
                <% @stores.each do |store| %>
                  <option value="<%= store.id %>" <%= "selected" if @store_filter == store.id.to_s %>><%= store.shop_domain %></option>
                <% end %>
              </select>
              <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Active filters display %>
    <% active_filters = [] %>
    <% active_filters << ["destination", "Destination: #{@destination}"] if @destination %>
    <% active_filters << ["origin_carrier", "Origin carrier: #{@origin_carrier_filter}"] if @origin_carrier_filter %>
    <% active_filters << ["destination_carrier", "Dest carrier: #{@destination_carrier_filter}"] if @destination_carrier_filter %>
    <% active_filters << ["status", "Status: #{@status_filter}"] if @status_filter %>
    <% active_filters << ["store_id", "Store: #{@stores.find { |s| s.id.to_s == @store_filter }&.shop_domain}"] if @store_filter %>
    <% active_filters << ["tags[]", "Tags: #{@tag_filters.join(", ")}"] if @tag_filters&.any? %>
    <% active_filters << ["event_from", "Event from: #{@event_from}"] if @event_from %>
    <% active_filters << ["event_to", "Event to: #{@event_to}"] if @event_to %>
    <% active_filters << ["shipped_from", "Shipped from: #{@shipped_from}"] if @shipped_from %>
    <% active_filters << ["shipped_to", "Shipped to: #{@shipped_to}"] if @shipped_to %>
    <% active_filters << ["transit_min", "Transit ≥ #{@transit_min}d"] if @transit_min %>
    <% active_filters << ["transit_max", "Transit ≤ #{@transit_max}d"] if @transit_max %>
    <% if active_filters.any? %>
      <div class="flex flex-wrap items-center gap-2">
        <% active_filters.each do |filter_name, label| %>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 text-sm bg-blue-50 text-blue-700 rounded-md border border-blue-200">
            <%= label %>
            <button type="button" data-action="click->shipment-filter#clearFilter" data-filter-name="<%= filter_name %>"
                    class="text-blue-400 hover:text-blue-600">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>
          </span>
        <% end %>
        <button type="button" data-action="click->shipment-filter#clearAllFilters"
                class="text-sm text-gray-500 hover:text-gray-700"><%= t("shipments.clear_all") %></button>
      </div>
    <% end %>
  <% end %>

  <%# Table %>
  <% if @shipments.any? %>
    <div data-controller="shipment-bulk" data-shipment-bulk-copied-text-value="<%= t("shipments.bulk.copied") %>">
    <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-center w-10">
              <input type="checkbox" data-shipment-bulk-target="selectAll" data-action="change->shipment-bulk#toggleAll"
                     aria-label="<%= t("shipments.bulk.select_all") %>"
                     class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap">
              <%= t("shipments.columns.tracking_no") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="order_info">
              <%= t("shipments.columns.order_info") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="status">
              <%= t("shipments.columns.status") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="sub_status">
              <%= t("shipments.columns.sub_status") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="latest_event">
              <%= t("shipments.columns.latest_event") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="origin_carrier">
              <%= t("shipments.columns.origin_carrier") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="destination_carrier">
              <%= t("shipments.columns.destination_carrier") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="destination">
              <%= t("shipments.columns.destination") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="transit_time">
              <%= t("shipments.columns.transit_time") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="tags">
              <%= t("shipments.columns.tags") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap" data-column="shop_name">
              <%= t("shipments.columns.shop_name") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="origin">
              <%= t("shipments.columns.origin") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="input_time">
              <%= t("shipments.columns.input_time") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="ordered_time">
              <%= t("shipments.columns.ordered_time") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="shipping_time">
              <%= t("shipments.columns.shipping_time") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="shopify_order_tag">
              <%= t("shipments.columns.shopify_order_tag") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="latest_event_update_time">
              <%= t("shipments.columns.latest_event_update_time") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="order_amount">
              <%= t("shipments.columns.order_amount") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="customer_name">
              <%= t("shipments.columns.customer_name") %>
            </th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider whitespace-nowrap hidden" data-column="customer_email">
              <%= t("shipments.columns.customer_email") %>
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @shipments.each do |shipment| %>
            <% order = shipment.order %>
            <% customer = order.customer %>
            <% tz = ActiveSupport::TimeZone["Asia/Shanghai"] %>
            <tr class="hover:bg-gray-50">
              <%# Checkbox %>
              <td class="px-4 py-3 text-center w-10">
                <input type="checkbox" data-shipment-bulk-target="checkbox" data-action="change->shipment-bulk#toggleOne"
                       data-fulfillment-id="<%= shipment.id %>"
                       data-tracking-number="<%= shipment.tracking_number %>"
                       data-tags="<%= shipment.tags.to_json %>"
                       data-last-event-date="<%= shipment.last_event_at&.in_time_zone(tz)&.strftime("%-m月%-d日") %>"
                       data-latest-event="<%= shipment.latest_event_description %>"
                       aria-label="<%= t("shipments.bulk.select_shipment", tracking: shipment.tracking_number) %>"
                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
              </td>

              <%# Tracking No. (always visible) %>
              <td class="px-4 py-3 text-sm font-mono text-gray-900 whitespace-nowrap">
                <%= link_to shipment.tracking_number, shipment_path(shipment), class: "text-blue-600 hover:underline" %>
              </td>

              <%# Order info %>
              <td class="px-4 py-3 text-sm whitespace-nowrap" data-column="order_info">
                <span class="text-blue-600 font-medium"><%= order.name || "##{order.shopify_order_id}" %></span>
              </td>

              <%# Status %>
              <td class="px-4 py-3 whitespace-nowrap" data-column="status">
                <% if shipment.tracking_status.present? %>
                  <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium <%= shipment.status_badge_classes %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= shipment.status_dot_class %>"></span>
                    <%= shipment.tracking_status_display %>
                  </span>
                <% else %>
                  <span class="text-xs text-gray-400">--</span>
                <% end %>
              </td>

              <%# Sub-status %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap" data-column="sub_status">
                <%= shipment.tracking_sub_status.present? ? shipment.tracking_sub_status.gsub(/([a-z])([A-Z])/, '\1 \2').gsub("_", " ") : "--" %>
              </td>

              <%# Latest event %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap max-w-xs truncate" data-column="latest_event">
                <% if shipment.last_event_at.present? && shipment.latest_event_description.present? %>
                  <%= shipment.last_event_at.in_time_zone(tz).strftime("%-d %b, %Y %H:%M:%S") %>, <%= shipment.latest_event_description.truncate(40) %>
                <% else %>
                  --
                <% end %>
              </td>

              <%# Origin carrier %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap" data-column="origin_carrier">
                <%= shipment.origin_carrier || "--" %>
              </td>

              <%# Destination carrier %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap" data-column="destination_carrier">
                <%= shipment.destination_carrier || "--" %>
              </td>

              <%# Destination %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap" data-column="destination">
                <%= shipment.destination_country || "--" %>
              </td>

              <%# Transit time %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap" data-column="transit_time">
                <%= shipment.transit_days.present? ? "#{shipment.transit_days} days" : "--" %>
              </td>

              <%# Tags %>
              <td class="px-4 py-3 text-sm whitespace-nowrap hidden" data-column="tags">
                <% if shipment.tags.present? %>
                  <% shipment.tags.each do |tag| %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-gray-100 text-gray-700 mr-1"><%= tag %></span>
                  <% end %>
                <% else %>
                  --
                <% end %>
              </td>

              <%# Shop name %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap" data-column="shop_name">
                <%= order.shopify_store&.shop_domain&.gsub(".myshopify.com", "") || "--" %>
              </td>

              <%# Origin %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap hidden" data-column="origin">
                <%= shipment.origin_country || "--" %>
              </td>

              <%# Input time %>
              <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap hidden" data-column="input_time">
                <%= shipment.created_at.in_time_zone(tz).strftime("%-d %b, %Y %H:%M") %>
              </td>

              <%# Ordered time %>
              <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap hidden" data-column="ordered_time">
                <%= order.ordered_at ? order.ordered_at.in_time_zone(tz).strftime("%-d %b, %Y %H:%M") : "--" %>
              </td>

              <%# Shipping time %>
              <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap hidden" data-column="shipping_time">
                <%= shipment.shipped_at ? shipment.shipped_at.in_time_zone(tz).strftime("%-d %b, %Y %H:%M") : "--" %>
              </td>

              <%# Shopify order tag %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap hidden" data-column="shopify_order_tag">
                <%= order.shopify_data&.dig("tags").presence || "--" %>
              </td>

              <%# Latest event update time %>
              <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap hidden" data-column="latest_event_update_time">
                <%= shipment.last_event_at ? shipment.last_event_at.in_time_zone(tz).strftime("%-d %b, %Y %H:%M") : "--" %>
              </td>

              <%# Order amount %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap hidden" data-column="order_amount">
                <%= number_to_currency(order.total_price, unit: order.currency == "USD" ? "$" : "#{order.currency} ") %>
              </td>

              <%# Customer name %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap hidden" data-column="customer_name">
                <%= customer&.full_name || "--" %>
              </td>

              <%# Customer email %>
              <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap hidden" data-column="customer_email">
                <%= order.email || customer&.email || "--" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Bulk action bar %>
    <div data-shipment-bulk-target="bar" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-40">
      <div class="flex items-center gap-3 px-5 py-3 bg-white rounded-xl shadow-lg border border-gray-200">
        <span class="text-sm text-gray-600">
          <span data-shipment-bulk-target="count">0</span> <%= t("shipments.bulk.selected") %>
        </span>
        <div class="w-px h-5 bg-gray-200"></div>
        <button type="button" data-action="click->shipment-bulk#copyTracking"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
          </svg>
          <%= t("shipments.bulk.copy_tracking") %>
        </button>
        <button type="button" data-action="click->shipment-bulk#copyTrackingSimple"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
          </svg>
          <%= t("shipments.bulk.copy_tracking_simple") %>
        </button>
        <button type="button" data-action="click->shipment-bulk#openTagModal"
                data-tag-mode="add" data-url="<%= bulk_add_tags_shipments_path(archived: @archived ? "true" : nil) %>"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
          </svg>
          <%= t("shipments.bulk.add_tags") %>
        </button>
        <button type="button" data-action="click->shipment-bulk#openTagModal"
                data-tag-mode="delete" data-url="<%= bulk_remove_tags_shipments_path(archived: @archived ? "true" : nil) %>"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
          </svg>
          <%= t("shipments.bulk.delete_tags") %>
        </button>
        <div class="w-px h-5 bg-gray-200"></div>
        <% if @archived %>
          <button type="button" data-action="click->shipment-bulk#submitBulkAction"
                  data-url="<%= bulk_unarchive_shipments_path(archived: "true") %>"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5m6 4.125 2.25 2.25m0 0 2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
            </svg>
            <%= t("shipments.bulk.unarchive") %>
          </button>
        <% else %>
          <button type="button" data-action="click->shipment-bulk#submitBulkAction"
                  data-url="<%= bulk_archive_shipments_path %>"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
            </svg>
            <%= t("shipments.bulk.archive") %>
          </button>
        <% end %>
      </div>
    </div>
    <form data-shipment-bulk-target="archiveForm" method="post" class="hidden"></form>

    <%# Tag modal %>
    <div data-controller="shipment-tags"
         data-shipment-tags-available-tags-url-value="<%= available_tags_shipments_path %>"
         data-shipment-tags-add-title-value="<%= t("shipments.tags.add_tags") %>"
         data-shipment-tags-delete-title-value="<%= t("shipments.tags.delete_tags") %>"
         data-shipment-tags-added-label-value="<%= t("shipments.tags.added_label") %>"
         data-shipment-tags-selected-label-value="<%= t("shipments.tags.selected_label") %>"
         data-shipment-tags-available-label-value="<%= t("shipments.tags.available_label") %>"
         data-shipment-tags-no-tags-text-value="<%= t("shipments.tags.no_tags") %>"
         data-shipment-tags-no-tags-found-text-value="<%= t("shipments.tags.no_tags_found") %>">
      <%= render "shipments/tag_modal" %>
    </div>
    </div>

    <%# Pagination %>
    <% if @total_pages > 1 %>
      <nav class="flex items-center justify-between">
        <p class="text-sm text-gray-600">
          <%= t("shipments.showing", from: (@page - 1) * ShipmentsController::PER_PAGE + 1, to: [(@page) * ShipmentsController::PER_PAGE, @total_count].min, total: @total_count) %>
        </p>
        <div class="flex gap-1">
          <% if @page > 1 %>
            <%= link_to t("shipments.prev"), request.params.merge(page: @page - 1),
                class: "px-3 py-1 text-sm rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50" %>
          <% end %>
          <% pagination_range(@page, @total_pages).each do |p| %>
            <% if p == :gap %>
              <span class="px-2 py-1 text-sm text-gray-400">...</span>
            <% else %>
              <%= link_to p, request.params.merge(page: p),
                  class: "px-3 py-1 text-sm rounded-md border #{p == @page ? 'border-blue-500 bg-blue-50 text-blue-700 font-medium' : 'border-gray-300 bg-white text-gray-700 hover:bg-gray-50'}" %>
            <% end %>
          <% end %>
          <% if @page < @total_pages %>
            <%= link_to t("shipments.next"), request.params.merge(page: @page + 1),
                class: "px-3 py-1 text-sm rounded-md border border-gray-300 bg-white text-gray-700 hover:bg-gray-50" %>
          <% end %>
        </div>
      </nav>
    <% end %>
  <% else %>
    <div class="bg-white rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500"><%= t("shipments.empty") %></p>
    </div>
  <% end %>
</div>
