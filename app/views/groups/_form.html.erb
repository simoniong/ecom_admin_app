<%= form_with model: @group, local: true do |f| %>
  <div class="space-y-4">
    <div>
      <%= f.label :name, t("groups.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-gray-900 focus:ring-gray-900" %>
      <% if @group.errors[:name].any? %>
        <p class="mt-1 text-sm text-red-600"><%= @group.errors[:name].first %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :description, t("groups.description"), class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 3, class: "block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-gray-900 focus:ring-gray-900" %>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit (@group.persisted? ? t("groups.update") : t("groups.create")), class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
      <%= link_to t("groups.cancel"), groups_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  </div>
<% end %>
