<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("groups.title") %></h1>
    <%= link_to t("groups.new"), new_group_path, class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2" %>
  </div>

  <p class="mt-2 text-sm text-gray-600"><%= t("groups.description_lead") %></p>

  <% if @groups.any? %>
    <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200">
      <div class="divide-y divide-gray-200">
        <% @groups.each do |group| %>
          <div class="flex items-center justify-between px-6 py-4">
            <div>
              <div class="text-sm font-medium text-gray-900"><%= group.name %></div>
              <% if group.description.present? %>
                <p class="mt-1 text-xs text-gray-500"><%= group.description %></p>
              <% end %>
              <p class="mt-1 text-xs text-gray-500">
                <%= t("groups.counts.members", count: group.memberships.count) %>
                ·
                <%= t("groups.counts.shopify_stores", count: group.shopify_stores.count) %>
                ·
                <%= t("groups.counts.ad_accounts", count: group.ad_accounts.count) %>
                ·
                <%= t("groups.counts.email_accounts", count: group.email_accounts.count) %>
              </p>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to t("groups.edit"), edit_group_path(group), class: "text-sm text-gray-600 hover:text-gray-900" %>
              <%= button_to group_path(group), method: :delete,
                  data: { turbo_confirm: t("groups.destroy_confirm", name: group.name) },
                  class: "text-sm text-red-600 hover:text-red-800" do %>
                <%= t("groups.destroy") %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6 text-sm text-gray-600">
      <%= t("groups.empty_state") %>
    </div>
  <% end %>
</div>
