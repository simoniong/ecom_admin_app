<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ecom Admin App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <div class="flex min-h-screen">
      <%= render "shared/sidebar" %>
      <main class="flex-1 p-6 overflow-auto">
        <% if notice.present? %>
          <p class="mb-4 p-3 bg-green-50 text-green-700 rounded-md text-sm"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="mb-4 p-3 bg-red-50 text-red-700 rounded-md text-sm"><%= alert %></p>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
