<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("companies.title") %></h1>
  </div>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <%= form_with model: @company, url: company_path, method: :patch do |f| %>
      <div class="mb-4">
        <%= f.label :name, t("companies.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-gray-900 focus:ring-gray-900" %>
        <% if @company.errors[:name].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @company.errors[:name].first %></p>
        <% end %>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit t("companies.save"), class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <% if current_membership&.owner? %>
    <div class="mt-6">
      <%= link_to invitations_path, class: "inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-gray-900" do %>
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        <%= t("companies.manage_members") %>
      <% end %>
    </div>
  <% end %>
</div>
