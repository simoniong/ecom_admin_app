<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-semibold text-gray-900"><%= t("companies.new_title") %></h1>
  <p class="mt-2 text-sm text-gray-600"><%= t("companies.new_lead") %></p>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <%= form_with model: @company, url: company_path, local: true do |f| %>
      <div class="mb-4">
        <%= f.label :name, t("companies.name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, required: true, class: "block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-gray-900 focus:ring-gray-900" %>
        <% if @company.errors[:name].any? %>
          <p class="mt-1 text-sm text-red-600"><%= @company.errors[:name].first %></p>
        <% end %>
      </div>

      <div class="mb-4">
        <%= f.label :locale, t("companies.locale"), class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :locale,
            Company::AVAILABLE_LOCALES.map { |loc| [ t("language_name", locale: loc), loc ] },
            { selected: @company.locale || I18n.default_locale.to_s },
            class: "block w-full px-3 py-2 bg-white border border-gray-300 rounded-md text-sm text-gray-700 focus:border-gray-900 focus:ring-gray-900" %>
        <p class="mt-1 text-xs text-gray-400"><%= t("companies.locale_hint") %></p>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit t("companies.create_submit"), class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
        <% if current_user.companies.any? %>
          <%= link_to t("companies.cancel"), authenticated_root_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
