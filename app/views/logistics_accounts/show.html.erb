<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("logistics_accounts.title") %></h1>
    <%= link_to t("logistics_channels.title"), logistics_channels_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>
  <p class="mt-1 text-sm text-gray-500"><%= t("logistics_accounts.description") %></p>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <h2 class="text-lg font-medium text-gray-900"><%= t("logistics_accounts.status") %></h2>
    <dl class="mt-3 divide-y divide-gray-200">
      <div class="py-2 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("logistics_accounts.customer_id") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono"><%= @logistics_account.customer_id.presence || "—" %></dd>
      </div>
      <div class="py-2 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("logistics_accounts.customer_userid") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono"><%= @logistics_account.customer_userid.presence || "—" %></dd>
      </div>
    </dl>

    <%= button_to t("logistics_accounts.test_authenticate"), authenticate_logistics_account_path, method: :post,
        class: "mt-4 inline-flex items-center gap-2 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2" %>
  </div>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <h2 class="text-lg font-medium text-gray-900"><%= t("logistics_accounts.credentials") %></h2>
    <p class="mt-1 text-sm text-gray-500"><%= t("logistics_accounts.credentials_hint") %></p>

    <%= form_with model: @logistics_account, url: logistics_account_path, method: :patch, class: "mt-4 space-y-4" do |f| %>
      <% if @logistics_account.errors.any? %>
        <div class="p-3 bg-red-50 border border-red-200 rounded-md">
          <% @logistics_account.errors.full_messages.each do |msg| %>
            <p class="text-sm text-red-600"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-gray-700" for="logistics_account_username"><%= t("logistics_accounts.username") %></label>
        <%= f.text_field :username, class: "mt-1 w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700" for="logistics_account_password"><%= t("logistics_accounts.password") %></label>
        <%= f.password_field :password, value: nil, autocomplete: "new-password",
              placeholder: t("logistics_accounts.password_placeholder"),
              class: "mt-1 w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
        <p class="mt-1 text-xs text-gray-500"><%= t("logistics_accounts.password_hint") %></p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700" for="logistics_account_url1_base"><%= t("logistics_accounts.url1_base") %></label>
        <%= f.text_field :url1_base, class: "mt-1 w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700" for="logistics_account_url2_base"><%= t("logistics_accounts.url2_base") %></label>
        <%= f.text_field :url2_base, class: "mt-1 w-full max-w-md border border-gray-300 rounded px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.submit t("logistics_accounts.save"),
              class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
