<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-semibold text-gray-900"><%= t("ad_accounts.select_accounts") %></h1>
  <p class="mt-2 text-sm text-gray-600"><%= t("ad_accounts.select_accounts_description") %></p>

  <%= form_tag meta_select_accounts_path, method: :post, data: { turbo: false }, class: "mt-6" do %>
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 divide-y divide-gray-200">
      <% @ad_accounts.each do |account| %>
        <label class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 cursor-pointer">
          <%= check_box_tag "account_ids[]", account["account_id"], true, class: "h-4 w-4 rounded border-gray-300 text-gray-900 focus:ring-gray-900" %>
          <%= hidden_field_tag "account_names[#{account["account_id"]}]", account["name"] %>
          <div>
            <span class="text-sm font-medium text-gray-900"><%= account["name"] || t("ad_accounts.unnamed_account") %></span>
            <span class="ml-2 text-xs text-gray-500 font-mono">act_<%= account["account_id"] %></span>
          </div>
        </label>
      <% end %>
    </div>

    <div class="mt-4 flex justify-end">
      <%= submit_tag t("ad_accounts.select_accounts_submit"),
          class: "inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 cursor-pointer" %>
    </div>
  <% end %>
</div>
