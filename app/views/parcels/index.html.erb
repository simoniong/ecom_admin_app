<div class="p-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold text-gray-900"><%= t("parcels.title") %></h1>
    <% if current_membership&.owner? %>
      <%= link_to t("parcels.import.title"), import_parcels_path,
            class: "px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-800" %>
    <% end %>
  </div>

  <nav class="flex gap-4 border-b border-gray-200 mb-4">
    <%= link_to t("parcels.tab_orders"), parcels_path,
          class: "pb-2 text-sm font-medium #{@tab == 'orders' ? 'border-b-2 border-gray-900 text-gray-900' : 'text-gray-500 hover:text-gray-700'}" %>
    <%= link_to t("parcels.tab_unmatched"), parcels_path(tab: "unmatched"),
          class: "pb-2 text-sm font-medium #{@tab == 'unmatched' ? 'border-b-2 border-gray-900 text-gray-900' : 'text-gray-500 hover:text-gray-700'}" %>
  </nav>

  <% if @tab == "unmatched" %>
    <%# Rendered once regardless of how many unmatched rows are on the page —
        see app/javascript/controllers/lazy_options_controller.js. Each row's
        <select> clones this template's <option>s in client-side rather than
        the server writing the full order list into every row's markup. %>
    <template id="assignable-orders-options">
      <%= options_from_collection_for_select(@assignable_orders, :id, :name) %>
    </template>
    <table class="min-w-full divide-y divide-gray-200 bg-white rounded-lg border border-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.identifier") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.tracking") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.channel") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.cost") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.assign") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @parcels.each do |parcel| %>
          <%= render "parcels/unmatched_row", parcel: parcel %>
        <% end %>
      </tbody>
    </table>
    <%= render "parcels/pagination", page: @page, total_pages: @total_pages, total_count: @total_count %>
  <% else %>
    <%= form_tag parcels_path, method: :get, class: "bg-white rounded-lg border border-gray-200 p-4 mb-4 flex flex-wrap gap-4 items-end" do %>
      <div>
        <label for="from_date" class="block text-xs font-medium text-gray-500 mb-1"><%= t("parcels.from_date") %></label>
        <%= date_field_tag :from_date, @from_date, class: "rounded-md border-gray-300 text-sm" %>
      </div>
      <div>
        <label for="to_date" class="block text-xs font-medium text-gray-500 mb-1"><%= t("parcels.to_date") %></label>
        <%= date_field_tag :to_date, @to_date, class: "rounded-md border-gray-300 text-sm" %>
      </div>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= check_box_tag :multi_parcel_only, "1", params[:multi_parcel_only].present?, class: "rounded border-gray-300" %>
        <%= t("parcels.multi_parcel_only") %>
      </label>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= check_box_tag :over_only, "1", params[:over_only].present?, class: "rounded border-gray-300" %>
        <%= t("parcels.over_only") %>
      </label>
      <div>
        <label for="min_over_pct" class="block text-xs font-medium text-gray-500 mb-1"><%= t("parcels.min_over_pct") %> %</label>
        <%= number_field_tag :min_over_pct, @min_over_pct, min: 0, step: "any", class: "w-24 rounded-md border-gray-300 text-sm" %>
      </div>
      <%= submit_tag t("parcels.filter"), class: "px-4 py-2 bg-gray-900 text-white text-sm rounded-md cursor-pointer" %>
      <%= link_to t("parcels.export.button"), export_parcels_path(request.query_parameters),
            class: "px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-50" %>
    <% end %>

    <div data-controller="edit-mode" data-edit-mode-editing-class="parcels-editing" class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.order") %></th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.estimated") %></th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.actual") %></th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">
                <%= link_to t("parcels.columns.variance"),
                      parcels_path(request.query_parameters.merge(sort_column: "variance",
                        sort_direction: (@sort_column == "variance" && @sort_direction == "desc") ? "asc" : "desc")),
                      class: "hover:text-gray-700" %>
              </th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.variance_pct") %></th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase"><%= t("parcels.columns.parcel_count") %></th>
              <th class="px-4 py-3 text-right">
                <label class="inline-flex items-center gap-1.5 text-xs font-normal normal-case text-gray-500 cursor-pointer">
                  <%= check_box_tag "edit_mode", "1", false, id: "edit_mode_toggle",
                        data: { action: "change->edit-mode#toggle" }, class: "rounded border-gray-300" %>
                  <%= t("parcels.edit_mode") %>
                </label>
              </th>
            </tr>
          </thead>
          <% @orders.each do |order| %>
            <% result = @comparisons[order.id] %>
            <% order_variance_cny = (result.order_estimate_cny && result.actual_total_cny) ? (result.actual_total_cny - result.order_estimate_cny) : nil %>
            <% order_variance_usd = (result.order_estimate && order.actual_shipping_cost) ? (order.actual_shipping_cost - result.order_estimate) : nil %>
            <% order_variance_pct = (order_variance_cny && result.order_estimate_cny&.nonzero?) ? (order_variance_cny / result.order_estimate_cny * 100).round(2) : nil %>
            <tbody data-controller="collapsible" class="divide-y divide-gray-100 border-t border-gray-100">
              <tr class="cursor-pointer hover:bg-gray-50"
                  data-action="click->collapsible#toggle keydown.enter->collapsible#toggle keydown.space->collapsible#toggle:prevent"
                  role="button" tabindex="0">
                <td class="px-4 py-3 text-sm font-medium text-gray-900">
                  <svg data-collapsible-target="icon" class="inline w-3 h-3 text-gray-400 transition-transform mr-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                  <%= order.name %>
                  <% if result.any_zone_mismatch %>
                    <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-red-50 text-red-600"><%= t("parcels.zone_mismatch_badge") %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right"><%= dual_currency(result.order_estimate_cny, result.order_estimate) %></td>
                <td class="px-4 py-3 text-right"><%= dual_currency(result.actual_total_cny, order.actual_shipping_cost) %></td>
                <td class="px-4 py-3 text-right"><%= dual_currency(order_variance_cny, order_variance_usd, over: order_variance_cny.to_f.positive?, sign: true) %></td>
                <td class="px-4 py-3 text-right text-sm <%= "text-red-600 font-medium" if order_variance_pct && order_variance_pct.positive? %>">
                  <%= order_variance_pct ? "#{order_variance_pct}%" : "—" %>
                </td>
                <td class="px-4 py-3 text-right text-sm <%= order.parcels.size > 1 ? "text-amber-600 font-medium" : "text-gray-500" %>">
                  <%= order.parcels.size %>
                </td>
                <td class="px-4 py-3"></td>
              </tr>
              <tr data-collapsible-target="content" class="hidden bg-gray-50">
                <td colspan="7" class="px-4 py-4">
                  <% if result.basis.nil? %>
                    <div class="text-xs text-gray-500 mb-3"><%= t("parcels.basis.unavailable") %></div>
                  <% else %>
                    <% code = parcel_order_country_code(order) %>
                    <div class="flex flex-wrap items-center gap-2 bg-white border border-gray-200 border-l-4 border-l-gray-900 rounded-lg px-3 py-2.5 mb-3 text-xs text-gray-700">
                      <span class="text-[10px] font-semibold tracking-wide text-gray-400 uppercase"><%= t("parcels.basis.label") %></span>
                      <span class="px-2 py-1 rounded bg-gray-50 border border-gray-200 text-[11px]"><%= parcel_country_flag(code) %> <%= parcel_country_name(code) %></span>
                      <span class="px-2 py-1 rounded font-mono text-[11px] <%= result.zoned ? "bg-amber-50 text-amber-700" : "bg-gray-50 border border-gray-200" %>">
                        <%= result.zoned ? t("parcels.basis.zone", zone: result.estimated_zone) : t("parcels.basis.unzoned") %>
                      </span>
                      <span class="text-gray-300">&middot;</span>
                      <span class="px-2 py-1 rounded bg-gray-50 border border-gray-200 font-mono text-[11px]">
                        <%= t("parcels.basis.weight", weight: number_with_precision(result.order_weight_kg, precision: 2)) %>
                      </span>
                      <% if band = result.basis.display_band %>
                        <span class="px-2 py-1 rounded bg-gray-50 border border-gray-200 font-mono text-[11px]">
                          <%= t("parcels.basis.band", min: band.weight_min_kg, max: band.weight_max_kg) %>
                        </span>
                        <span class="text-gray-300">&rarr;</span>
                        <span class="px-2 py-1 rounded bg-gray-50 border border-gray-200 font-mono text-[11px]">
                          <%= t("parcels.basis.formula", rate: cny(band.per_kg_rate_cny), weight: number_with_precision(result.order_weight_kg, precision: 2), flat: cny(band.flat_fee_cny)) %>
                        </span>
                      <% end %>
                      <span class="ml-auto font-semibold text-gray-900 text-sm whitespace-nowrap">
                        = <%= dual_currency(result.order_estimate_cny, result.order_estimate) %>
                      </span>
                    </div>
                  <% end %>

                  <div class="overflow-x-auto">
                    <table class="min-w-full text-xs">
                      <thead>
                        <tr class="text-gray-500">
                          <th class="py-1 text-left"><%= t("parcels.parcel_table.parcel") %></th>
                          <th class="py-1 text-left"><%= t("parcels.parcel_table.channel") %></th>
                          <th class="py-1 text-right"><%= t("parcels.parcel_table.zone") %><br><span class="font-normal text-[10px] text-gray-400"><%= t("parcels.parcel_table.zone_hint") %></span></th>
                          <th class="py-1 text-right"><%= t("parcels.parcel_table.billed_weight") %></th>
                          <th class="py-1 text-right"><%= t("parcels.parcel_table.estimate") %><br><span class="font-normal text-[10px] text-gray-400"><%= t("parcels.parcel_table.currency_hint") %></span></th>
                          <th class="py-1 text-right"><%= t("parcels.parcel_table.actual") %><br><span class="font-normal text-[10px] text-gray-400"><%= t("parcels.parcel_table.currency_hint") %></span></th>
                          <th class="py-1 text-right"><%= t("parcels.parcel_table.variance") %><br><span class="font-normal text-[10px] text-gray-400"><%= t("parcels.parcel_table.currency_hint") %></span></th>
                          <th class="py-1 text-right"><%= t("parcels.parcel_table.variance_pct") %></th>
                          <th class="parcels-edit-col py-1 text-right"><%= t("parcels.parcel_table.actions") %></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% result.parcel_lines.each do |line| %>
                          <%= render "parcels/parcel_row", parcel: line.parcel, line: line, estimated_zone: result.estimated_zone %>
                        <% end %>
                      </tbody>
                      <tfoot>
                        <% estimate_sum_usd = result.parcel_lines.filter_map(&:estimate).sum %>
                        <% actual_sum_usd = result.parcel_lines.sum(&:actual) %>
                        <% total_variance_cny = result.actual_total_cny - result.parcels_estimate_cny %>
                        <% total_variance_usd = actual_sum_usd - estimate_sum_usd %>
                        <tr class="border-t-2 border-gray-300 font-semibold text-gray-900">
                          <td class="py-2 text-left text-gray-500 font-medium" colspan="3">
                            <%= t("parcels.parcel_table.totals", count: result.parcel_lines.size) %>
                          </td>
                          <td class="py-2 text-right">
                            <% if result.billed_weight_total_kg %>
                              <%= number_with_precision(result.billed_weight_total_kg, precision: 2) %> kg
                              <% if result.order_weight_kg %>
                                <% heavier = result.billed_weight_total_kg > result.order_weight_kg %>
                                <span class="ml-1 inline-block px-1.5 py-0.5 rounded-full text-[10px] font-semibold <%= heavier ? "bg-red-50 text-red-600" : "bg-gray-100 text-gray-500" %>">
                                  <%= t("parcels.parcel_table.weight_estimate_note", weight: number_with_precision(result.order_weight_kg, precision: 2)) %>
                                  <% if heavier %>
                                    &middot; <%= t("parcels.parcel_table.weight_delta", delta: number_with_precision(result.billed_weight_total_kg - result.order_weight_kg, precision: 2)) %>
                                  <% else %>
                                    &middot; <%= t("parcels.parcel_table.weight_flat") %>
                                  <% end %>
                                </span>
                              <% end %>
                            <% else %>
                              —
                            <% end %>
                          </td>
                          <td class="py-2 text-right">
                            <%= dual_currency(result.parcels_estimate_cny, estimate_sum_usd) %>
                            <% if result.decomposable && result.parcel_lines.size > 1 %>
                              <div class="text-[10px] font-normal text-purple-600 mt-0.5">
                                <%= t("parcels.parcel_table.split_note", count: result.parcel_lines.size, amount: signed_cny(result.split_cost_cny)) %>
                              </div>
                            <% end %>
                          </td>
                          <td class="py-2 text-right"><%= dual_currency(result.actual_total_cny, actual_sum_usd) %></td>
                          <td class="py-2 text-right" colspan="2">
                            <%= dual_currency(total_variance_cny, total_variance_usd, over: total_variance_cny.positive?, sign: true) %>
                          </td>
                          <td class="parcels-edit-col"></td>
                        </tr>
                      </tfoot>
                    </table>
                  </div>

                  <% if result.decomposable && result.order_estimate_cny %>
                    <%# Both USD terms below are derived from the same basis
                        (CNY ÷ result.basis.fx_rate) that the split/overcharge
                        CNY figures already use, and the displayed "total" USD
                        is their sum — never the order-row rollup
                        (order_variance_usd) — so this section can never show
                        a total that doesn't equal split + overcharge on
                        screen, even though per-parcel USD rounding means it
                        can drift from the rollup used elsewhere on the page. %>
                    <% split_usd = (result.split_cost_cny / result.basis.fx_rate).round(2) %>
                    <% overcharge_usd = (result.overcharge_cny / result.basis.fx_rate).round(2) %>
                    <% recon_total_usd = split_usd + overcharge_usd %>
                    <div class="mt-3 bg-purple-50 border border-gray-200 rounded-lg px-3.5 py-3 text-xs text-gray-700">
                      <div class="font-semibold mb-2 <%= "text-red-600" if result.any_zone_mismatch %>">
                        <% if result.any_zone_mismatch %>
                          <%= t("parcels.recon.question_mismatch") %>
                        <% else %>
                          <%= t("parcels.recon.question", cny: signed_cny(order_variance_cny), usd: signed_usd(recon_total_usd)) %>
                        <% end %>
                      </div>
                      <div class="flex flex-wrap items-center gap-2 text-sm">
                        <span class="flex flex-col">
                          <span class="font-semibold text-red-600"><%= signed_cny(order_variance_cny) %></span>
                          <span class="text-[10px] text-gray-400"><%= t("parcels.recon.total_label") %> &middot; <%= signed_usd(recon_total_usd) %></span>
                        </span>
                        <span class="text-gray-300">=</span>
                        <span class="flex flex-col">
                          <span class="font-semibold text-purple-600"><%= signed_cny(result.split_cost_cny) %></span>
                          <span class="text-[10px] text-gray-400">
                            <%= result.parcel_lines.size > 1 ? t("parcels.recon.split_label") : t("parcels.recon.split_label_single") %>
                            &middot; <%= signed_usd(split_usd) %>
                          </span>
                        </span>
                        <span class="text-gray-300">+</span>
                        <span class="flex flex-col">
                          <span class="font-semibold text-red-600"><%= signed_cny(result.overcharge_cny) %></span>
                          <span class="text-[10px] text-gray-400">
                            <%= t("parcels.recon.overcharge_label") %>
                            &middot; <%= signed_usd(overcharge_usd) %>
                          </span>
                        </span>
                      </div>
                    </div>
                  <% elsif result.order_estimate_cny.present? && result.parcel_lines.present? %>
                    <p class="mt-2 text-[11px] text-gray-400"><%= t("parcels.recon.unavailable") %></p>
                  <% end %>
                </td>
              </tr>
            </tbody>
          <% end %>
        </table>
      </div>
    </div>
    <%= render "parcels/pagination", page: @page, total_pages: @total_pages, total_count: @total_count %>
  <% end %>
</div>
