<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to ad_accounts_path, class: "text-gray-400 hover:text-gray-600" do %>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-semibold text-gray-900"><%= @ad_account.account_name || @ad_account.account_id %></h1>
    </div>

    <%= button_to ad_account_path(@ad_account), method: :delete,
        data: { turbo_confirm: t("ad_accounts.disconnect_confirm") },
        class: "inline-flex items-center gap-2 px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" do %>
      <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.181 8.68a4.503 4.503 0 0 1 1.903 6.405m-9.768-2.782L3.56 14.06a4.5 4.5 0 0 0 6.364 6.365l.164-.164m-3.07-8.355-2.122 2.122a4.5 4.5 0 0 0 6.364 6.364l2.122-2.122M10.5 13.5l3-3m2.818-2.818L18.56 5.44a4.5 4.5 0 0 0-6.364-6.364l-.164.163m3.07 8.355 2.122-2.122a4.5 4.5 0 0 0-6.364-6.364l-2.122 2.122" />
      </svg>
      <%= t("ad_accounts.disconnect") %>
    <% end %>
  </div>

  <div class="mt-6 bg-white shadow-sm rounded-lg border border-gray-200">
    <dl class="divide-y divide-gray-200">
      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("ad_accounts.show.platform") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800"><%= @ad_account.platform.capitalize %></span>
        </dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("ad_accounts.show.account_id") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 font-mono text-xs"><%= @ad_account.account_id %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("ad_accounts.show.account_name") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @ad_account.account_name.presence || "—" %></dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("ad_accounts.show.token_expires_at") %></dt>
        <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
          <% if @ad_account.token_expired? %>
            <span class="text-red-600 font-medium"><%= t("ad_accounts.token_expired") %></span>
          <% elsif @ad_account.token_expiring_soon? %>
            <span class="text-yellow-600 font-medium">
              <%= l(@ad_account.token_expires_at, format: :long) %>
              — <%= t("ad_accounts.token_expires_soon") %>
            </span>
          <% elsif @ad_account.token_expires_at %>
            <span class="text-gray-900"><%= l(@ad_account.token_expires_at, format: :long) %></span>
          <% else %>
            <span class="text-gray-900">—</span>
          <% end %>
        </dd>
      </div>

      <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-500"><%= t("ad_accounts.show.connected_at") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= l(@ad_account.created_at, format: :long) %></dd>
      </div>
    </dl>
  </div>
</div>
