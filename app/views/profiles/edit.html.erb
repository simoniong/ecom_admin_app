<div class="max-w-2xl mx-auto py-8 px-4">
  <h1 class="text-2xl font-semibold text-gray-900 mb-6"><%= t("profile.title") %></h1>

  <% if notice.present? %>
    <div class="mb-4 p-3 bg-green-50 border border-green-200 text-green-700 rounded-md text-sm">
      <%= notice %>
    </div>
  <% end %>

  <%= form_with model: current_user, url: profile_path, method: :patch, class: "space-y-6" do |f| %>
    <% if current_user.errors.any? %>
      <div class="p-3 bg-red-50 border border-red-200 text-red-700 rounded-md text-sm">
        <ul class="list-disc list-inside">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Personal Information %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="text-base font-semibold text-gray-900"><%= t("profile.personal_info") %></h3>
      </div>
      <div class="px-6 py-4 space-y-4">
        <div>
          <%= f.label :first_name, t("profile.first_name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
        </div>
        <div>
          <%= f.label :last_name, t("profile.last_name"), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
        </div>
      </div>
    </div>

    <%# Change Password %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="text-base font-semibold text-gray-900"><%= t("profile.change_password") %></h3>
        <p class="text-sm text-gray-500 mt-1"><%= t("profile.change_password_hint") %></p>
      </div>
      <div class="px-6 py-4 space-y-4">
        <div>
          <%= f.label :current_password, t("profile.current_password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
        </div>
        <div>
          <%= f.label :password, t("profile.new_password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
        </div>
        <div>
          <%= f.label :password_confirmation, t("profile.confirm_password"), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent" %>
        </div>
      </div>
    </div>

    <div>
      <%= f.submit t("profile.save"), class: "w-full bg-gray-900 text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 cursor-pointer" %>
    </div>
  <% end %>
</div>
